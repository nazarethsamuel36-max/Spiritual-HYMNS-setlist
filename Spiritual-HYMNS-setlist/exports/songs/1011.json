  "hashtags" : [ ],
  "sections" : [ {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "जायेंगे उत्तम देश में जरूर,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "रहेंगे प्रभु के साथ में जरूर;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "स्वर्गीय देश उत्तम भी वह है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 17
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "हमारा वह देश जो अद्भुत है ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "पिता को भाया है, हमारा एक राज्य है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "दुनिया की सृष्टि से, पहले बनाया है ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 27
      }, {
        "chord" : "G",
        "position" : 32
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "अद्भुत वह नगर भी है, ईश्वर की रचना है ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "दृढ़ता से नेव डाली है, स्थिर भी किया गया है ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "पवित्र नगर वह है, धार्मिकता रहती है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "स्वर्गीय स्वभाव से, तैयार भी किया है ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 26
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "सनातन राज्य वह है, युगानुयुग वह रहे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "रहेंगे सदा उसमें, जिनको उसने चुना है ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 24
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "प्रभु को देखेंगे, आनंद से भर जायेंगे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "उसकी महिमा में, हम सब मिल जायेंगे ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "उसके समान होंगे, हमारा जीवन वह है ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 31
      } ]
    } ]
  } ]
