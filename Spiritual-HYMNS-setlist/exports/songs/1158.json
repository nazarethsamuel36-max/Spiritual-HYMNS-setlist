        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 25
      } ]
    }, {
      "text" : "हिफाजत से रखता मुझे।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      } ]
