    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "एक मुंजी अजीब है खुदावंद यीशु,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "वह सचमुच अजीब है मुझे।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "चट्टान की दरार में वह लेकर मुझे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 29
      } ]
    }, {
      "text" : "छिपाता हर खौफ खतरे से।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
