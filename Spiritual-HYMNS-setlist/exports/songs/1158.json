        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    }, {
      "text" : "और मुझे संभालता मजबूत करता है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 22
      } ]
    }, {
      "text" : "नई ताकत भी देता हर रोज।",
