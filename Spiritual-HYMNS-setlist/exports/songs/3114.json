    "label" : "Verse 1",
    "lines" : [ {
      "text" : "रोशनी है तेरी सबसे महान"
    }, {
      "text" : "हम हैं ज़मीन और तू आसमान"
    }, {
      "text" : "जीवन ज्योति को जलाएँगे (2)"
    }, {
      "text" : "तेरे ही सामने यीशु महान"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "दे रहे हैं सदा हम उठाके हाथ"
    }, {
      "text" : "दिल से है आ रही एक ही आवाज़...२"
    }, {
      "text" : "तेरे करम से है मिली हयात (2)"
    }, {
      "text" : "तेरे ही दूं से चल रही साँस"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "यह मेरी ज़िंदगी है तेरी यीशु"
    }, {
      "text" : "मैं तेरी पनाह में अब सदा रहूं...२"
    }, {
      "text" : "जान देके तूने दी हमें नजात (2)"
    }, {
      "text" : "तेरे लहू से है मिली शिफा"
    } ]
  } ]
