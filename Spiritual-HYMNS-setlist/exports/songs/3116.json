  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "तेरी स्तुती गाये. . . हाल्लेलुयाह"
    }, {
      "text" : "तु है सबसे महान, तेरी जयजयकार"
    }, {
      "text" : "हा. . .ले.. .लु. . .या. . . ... (२)"
    }, {
      "text" : "तेरा नाम ऊँचा उठे, तेरा काम पुरा होवे (२)"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "सागर पर्वत भी, गाते महिमा का गान (२)"
    }, {
      "text" : "सारी सृष्टी गाती है, तु है कितना महान"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "सुरज चँदा भी, करते है आदर प्रणाम (२)"
    }, {
      "text" : "तेरी रचना गाती है, तु है कितना महान"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "संतो की सेना भी, गाती है हाल्लेलुया (२)"
    }, {
      "text" : "फरिस्ते गाते है, तु है कितना महान"
    } ]
  } ]
}