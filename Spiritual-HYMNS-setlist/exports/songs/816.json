  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "What a friend we have in Jesus,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "All our sins and griefs to bear!",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 17
      } ]
    }, {
      "text" : "What a privilege to carry",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "Everything to God in prayer!",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "O what peace we often forfeit,",
      "chords" : [ {
        "chord" : "A",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "O what needless pain we bear,",
      "chords" : [ {
        "chord" : "G",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    }, {
      "text" : "All because we do not carry",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "Everything to God in prayer!"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "Have we trials and temptations?",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "Is there trouble anywhere?",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 17
      } ]
    }, {
      "text" : "We should never be discouraged,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "Take it to the Lord in prayer.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "Can we find a friend so faithful,",
      "chords" : [ {
        "chord" : "A",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    }, {
      "text" : "Who will all our sorrows share?",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 17
      }, {
        "chord" : "A",
        "position" : 25
      } ]
    }, {
      "text" : "Jesus knows our every weakness,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "Take it to the Lord in prayer."
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
