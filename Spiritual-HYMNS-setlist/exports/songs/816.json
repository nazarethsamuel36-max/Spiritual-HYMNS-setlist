      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "Thou wilt find a solace there.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
