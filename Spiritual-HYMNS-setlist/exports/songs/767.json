{
  "id" : 767,
  "songNumber" : 155,
  "title" : "YESTERDAY TODAY FOREVER",
  "language" : "english",
  "originalKey" : "D",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Oh, how sweet the glorious message,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "Simple faith may claim;",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 17
      } ]
    }, {
      "text" : "Yesterday, today, forever,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "Jesus is the same.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Still He loves to save the sinful,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "Heal the sick and lame;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 18
      } ]
    }, {
      "text" : "Cheer the mourner, still the tempest;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    }, {
      "text" : "Glory to His name!",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Yesterday, today, forever,"
    }, {
      "text" : "Jesus is the same;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : "All may change, but Jesus never!",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "Glory to His name.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : "Glory to His name,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 13
      } ]
    }, {
      "text" : "Glory to His name;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : "All may change, but Jesus never!"
    }, {
      "text" : "Glory to His name."
    }, {
      "text" : ""
    }, {
      "text" : "He who was the friend of sinners,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "Seeks thee, lost one, now;",
      "chords" : [ {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : "Sinner, come, and at His footstool",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "Penitently bow.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 11
      } ]
    }, {
      "text" : "He who said, \"I'll not condemn thee,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "Go and sin no more;\"",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : "Speaks to thee that word of pardon,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "As in days of yore.",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Oft on earth He healed the suff'rer",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "By His mighty hand;",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : "Still our sicknesses and sorrows",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "Go at His command.",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : "He who gave His healing virtue,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "To a woman's touch;",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : "To the faith that claims His fullness,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    }, {
      "text" : "Still will give as much.",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "A",
        "position" : 19
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "He who pardoned erring Peter,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "Never need'st thou fear;",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 19
      } ]
    }, {
      "text" : "He that came to faithless Thomas,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "All thy doubt will clear.",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 19
      } ]
    }, {
      "text" : "He who let the loved disciple",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "On His bosom rest,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : "Bids thee still, with love as tender,",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 30
      } ]
    }, {
      "text" : "Lean upon His breast.",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "He who 'mid the raging billows,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "Walked upon the sea;",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 16
      } ]
    }, {
      "text" : "Still can hush our wildest tempest,",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "As on Galilee.",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 10
      } ]
    }, {
      "text" : "He who wept and prayed in anguish,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "In Gethsemane,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 9
      } ]
    }, {
      "text" : "Drinks with us each cup of trembling,",
      "chords" : [ {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "In our agony.",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "As of old He walked to Emmaus,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "With them to abide;",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : "So through all life's way He walketh,",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    }, {
      "text" : "Ever near our side.",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : "Soon again we shall behold Him,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "Hasten, Lord, the day !",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 18
      } ]
    }, {
      "text" : "But 'twill still be \"this same Jesus\"",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 31
      } ]
    }, {
      "text" : "As He went away.",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 12
      } ]
    } ]
  } ]
}