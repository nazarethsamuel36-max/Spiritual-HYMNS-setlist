        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "यीशु के हम गीत गायेंगे, उसके वचन को निभायेंगे",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
