    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "तेरे ही नाम में है मुक्ती, तेरे ही नाम में है शक्ती",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "तेरे ही नाम में मेरा विश्वास है, तेरे ही नाम में जिंदगी",
