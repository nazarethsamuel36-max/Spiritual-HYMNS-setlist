{
  "id" : 847,
  "songNumber" : 235,
  "title" : "THOU DOST SEEK A BRIDE",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Thou dost seek a Bride all pure and holy,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 27
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    }, {
      "text" : "Those who now belong to Thee alone,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 24
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "Those who give Thee all their heart's affections,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 30
      }, {
        "chord" : "D",
        "position" : 40
      } ]
    }, {
      "text" : "Of Thyself a part, bone of Thy bone.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "A",
        "position" : 24
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "Lord we answer to Thy heart's deep longing,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    }, {
      "text" : "Even so come quickly Lord we say,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    }, {
      "text" : "In our hearts we have the blessed answer,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 26
      }, {
        "chord" : "D",
        "position" : 34
      } ]
    }, {
      "text" : "Rise my love, my fair one come away.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "A",
        "position" : 26
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "Drawn from every kindred, tribe and nation",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 26
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    }, {
      "text" : "By Thy Holy Spirit's mighty power,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "Finding rest in Thee, God's great salvation",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 28
      }, {
        "chord" : "D",
        "position" : 37
      } ]
    }, {
      "text" : "Waits Thy Bride for Thine appointed hour.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "A",
        "position" : 28
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "Sharing with Thee in this world's rejection.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 26
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    }, {
      "text" : "Putting on Thy death to gain a crown,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 24
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : "By Thy Blood and Word we're overcomers,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 28
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    }, {
      "text" : "With Thee in Thy throne we shall sit down.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "A",
        "position" : 27
      }, {
        "chord" : "D",
        "position" : 37
      } ]
    } ]
  } ]
}