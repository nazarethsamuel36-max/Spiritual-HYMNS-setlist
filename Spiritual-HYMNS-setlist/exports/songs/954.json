    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Majesty, worship His Majesty,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "Unto Jesus be glory, honour and praise.",
      "chords" : [ {
        "chord" : "Em",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 32
      }, {
        "chord" : "D7",
        "position" : 39
      } ]
    }, {
      "text" : "Majesty, kingdom, authority,",
