        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "Flows from His throne unto His own,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 15
      }, {
        "chord" : "Am",
        "position" : 31
      } ]
    }, {
      "text" : "His anthem raise.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 11
      } ]
    }, {
      "text" : "So exalt, lift up on high,",
      "chords" : [ {
        "chord" : "Am",
        "position" : 5
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
