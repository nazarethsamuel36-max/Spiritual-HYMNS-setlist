      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "Em",
        "position" : 12
      } ]
    }, {
      "text" : "Magnify, come glorify Christ Jesus",
      "chords" : [ {
        "chord" : "Am",
        "position" : 5
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "the King,",
      "chords" : [ {
        "chord" : "B7",
        "position" : 4
      } ]
    }, {
      "text" : "Majesty, worship His Majesty,"
    }, {
