        "chord" : "G",
        "position" : 35
      }, {
        "chord" : "D",
        "position" : 45
      } ]
    }, {
      "text" : "We shall be in the sweet by and by;",
      "chords" : [ {
        "chord" : "A",
        "position" : 32
      } ]
    }, {
      "text" : "Happy praise to the King, through eternity sing,",
      "chords" : [ {
