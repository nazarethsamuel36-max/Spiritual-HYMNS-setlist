        "chord" : "G",
        "position" : 30
      }, {
        "chord" : "D",
        "position" : 39
      } ]
    }, {
      "text" : "'Tis a beautiful home of the soul;",
      "chords" : [ {
        "chord" : "A",
        "position" : 29
      } ]
    }, {
      "text" : "Built by Jesus on high, there we never shall die,",
      "chords" : [ {
