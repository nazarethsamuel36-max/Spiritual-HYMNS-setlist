  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "आ पवित्र आत्मा तू आ जा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "आ मैं प्रार्थना करूँ",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    }, {
      "text" : "और अपनी शक्ती ले आ जा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    }, {
      "text" : "आ अपने नम्रता में आ ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "ध्यान अपने बच्चों को दे दे,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "अंधो की रोशनी तू बन,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    }, {
      "text" : "निर्बल को शक्ती तू दे दे,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "ले मेरी आत्मा तन मन ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "सुखी की में चश्मा बहा दे,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "मुरझाये मन में तू आ,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "आ अपने सामर्थ्य में आ जा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "छुले संपूर्ण बना ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    } ]
  } ]
