{
  "id" : 764,
  "songNumber" : 152,
  "title" : "SHALL WE GATHER AT THE RIVER",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Shall we gather at the river,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Where bright angel feet have trod,",
      "chords" : [ {
        "chord" : "G",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    }, {
      "text" : "With its crystal tide forever,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      } ]
    }, {
      "text" : "Flowing by the throne of God?",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Yes, we'll gather at the river,",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      } ]
    }, {
      "text" : "The beautiful, the beautiful river;",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    }, {
      "text" : "Gather with the saints at the river",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "That flows by the throne of God.",
      "chords" : [ {
        "chord" : "A",
        "position" : 5
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "On the bosom of the river,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "Where the Saviour-King we own,",
      "chords" : [ {
        "chord" : "G",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    }, {
      "text" : "We shall meet and sorrow never,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      } ]
    }, {
      "text" : "'Neath the glory of the throne.",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "On the margin of the river,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "Washing up its silver spray,",
      "chords" : [ {
        "chord" : "G",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "We will walk and worship ever,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      } ]
    }, {
      "text" : "All the happy, golden day.",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "'Ere we reach the shining river,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Lay we every burden down;",
      "chords" : [ {
        "chord" : "G",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "Grace our spirits will deliver,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "And provide a robe and crown.",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "At the shining of the river,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "Mirror of the Saviour's face,",
      "chords" : [ {
        "chord" : "G",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    }, {
      "text" : "Saints whom death will never sever",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Lift their songs of saving grace.",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Soon we'll reach the shining river,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Soon our pilgrimage will cease;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "Soon our happy hearts will quiver",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "With the melody of peace.",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    } ]
  } ]
}