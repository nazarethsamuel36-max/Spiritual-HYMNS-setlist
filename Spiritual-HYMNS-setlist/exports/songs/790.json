  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "O Lord my God ! When I in awesome wonder",
      "chords" : [ {
        "chord" : "C",
        "position" : 2
      }, {
        "chord" : "F",
        "position" : 26
      } ]
    }, {
      "text" : "Consider all the works Thy hand hath made,",
      "chords" : [ {
        "chord" : "C",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "C",
        "position" : 37
      } ]
    }, {
      "text" : "I see the stars, I hear the mighty thunder",
      "chords" : [ {
        "chord" : "C",
        "position" : 2
      }, {
        "chord" : "F",
        "position" : 28
      } ]
    }, {
      "text" : "Thy power throughout the universe displayed ;",
      "chords" : [ {
        "chord" : "C",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "C",
        "position" : 37
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "Chorus",
    "lines" : [ {
      "text" : "Then sings my soul, my Saviour God to Thee,",
      "chords" : [ {
        "chord" : "C",
        "position" : 5
      }, {
        "chord" : "F",
        "position" : 23
      }, {
        "chord" : "C",
        "position" : 38
      } ]
    }, {
      "text" : "How great Thou art, how great Thou art !",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "C",
        "position" : 24
      }, {
        "chord" : "C",
        "position" : 35
      } ]
    }, {
      "text" : "Then sings my soul, my Saviour God to Thee,"
    }, {
      "text" : "How great Thou art, how great Thou art !"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "When through the woods and forest glades I wander",
      "chords" : [ {
        "chord" : "C",
        "position" : 5
      }, {
        "chord" : "F",
        "position" : 34
      } ]
    }, {
      "text" : "And hear the birds sing sweetly in the trees ;",
      "chords" : [ {
        "chord" : "C",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 24
      }, {
        "chord" : "C",
        "position" : 39
      } ]
    }, {
      "text" : "When I look down from lofty mountain grandeur,",
      "chords" : [ {
        "chord" : "C",
        "position" : 5
      }, {
        "chord" : "F",
        "position" : 28
      } ]
    }, {
      "text" : "And hear the brook, and feel the gentle breeze ;",
      "chords" : [ {
        "chord" : "C",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 24
      }, {
        "chord" : "C",
        "position" : 40
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "And when I think that God His Son not sparing,",
      "chords" : [ {
        "chord" : "C",
        "position" : 4
      }, {
        "chord" : "F",
        "position" : 30
      } ]
    }, {
      "text" : "Sent Him to die I scarce can take it in ;",
      "chords" : [ {
        "chord" : "C",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "C",
        "position" : 37
      } ]
    }, {
      "text" : "That on the cross my burden gladly bearing,",
      "chords" : [ {
        "chord" : "C",
        "position" : 5
      }, {
        "chord" : "F",
        "position" : 28
      } ]
    }, {
      "text" : "He bled and died to take away my sin ;",
      "chords" : [ {
        "chord" : "C",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "C",
        "position" : 33
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "When Christ shall come with shout of acclamation",
      "chords" : [ {
        "chord" : "C",
        "position" : 5
      }, {
        "chord" : "F",
        "position" : 37
      } ]
    }, {
      "text" : "And take me home what joy shall fill my heart !",
      "chords" : [ {
        "chord" : "C",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "C",
        "position" : 40
      } ]
    }, {
      "text" : "Then shall I bow in humble adoration",
      "chords" : [ {
        "chord" : "C",
        "position" : 5
      }, {
        "chord" : "F",
        "position" : 27
      } ]
    }, {
      "text" : "And there proclaim, my God, how great Thou art !",
      "chords" : [ {
        "chord" : "C",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 23
