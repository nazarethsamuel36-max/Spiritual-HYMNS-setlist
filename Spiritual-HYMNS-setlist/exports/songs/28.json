    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "From the rising of the sun",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
