      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "Praise Him all ye servants of the Lord,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
