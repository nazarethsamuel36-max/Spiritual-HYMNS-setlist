        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "Blessed be the name of the Lord",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "From this time forth,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
