{
  "id" : 752,
  "songNumber" : 140,
  "title" : "ROCK OF AGES",
  "language" : "english",
  "originalKey" : "D",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Rock of Ages, cleft for me,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    }, {
      "text" : "Let me hide myself in Thee;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "Let the water and the blood,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : "From Thy wounded side which flowed,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "Be of sin the double cure,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : "Save from wrath and make me pure.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Could my tears forever flow,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 18
      } ]
    }, {
      "text" : "Could my zeal no languor know,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "These for sin could not atone;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 20
      } ]
    }, {
      "text" : "Thou must save, and Thou alone;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    }, {
      "text" : "In my hand no price I bring,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : "Simply to Thy cross I cling.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "While I draw this fleeting breath,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 18
      } ]
    }, {
      "text" : "When my eyes should close in death,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    }, {
      "text" : "When I rise to worlds unknown,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 15
      } ]
    }, {
      "text" : "And behold Thee on Thy throne,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "Rock of Ages, cleft for me,"
    }, {
      "text" : "Let me hide myself in Thee.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    } ]
  } ]
}