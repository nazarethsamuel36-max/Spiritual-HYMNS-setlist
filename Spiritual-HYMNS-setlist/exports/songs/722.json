  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Give heed to my words, O Lord,",
      "chords" : [ {
        "chord" : "C",
        "position" : 5
      } ]
    }, {
      "text" : "Consider my meditation.",
      "chords" : [ {
        "chord" : "F",
        "position" : 3
      }, {
        "chord" : "C",
        "position" : 16
      } ]
    }, {
      "text" : "Hearken unto the voice of my cry,"
    }, {
      "text" : "My King and my God,",
      "chords" : [ {
        "chord" : "C",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "For Lord unto Thee will I pray.",
      "chords" : [ {
        "chord" : "C",
        "position" : 4
      } ]
    }, {
      "text" : "My voice shall Thou hear in the morning.",
      "chords" : [ {
        "chord" : "F",
        "position" : 3
      } ]
    }, {
      "text" : "O Lord in the morning will I direct my prayer",
      "chords" : [ {
        "chord" : "C",
        "position" : 14
      } ]
    }, {
      "text" : "Unto Thee, and will look up ! (repeat)",
      "chords" : [ {
        "chord" : "G",
        "position" : 5
      }, {
        "chord" : "C",
        "position" : 25
      } ]
    } ]
  } ]
