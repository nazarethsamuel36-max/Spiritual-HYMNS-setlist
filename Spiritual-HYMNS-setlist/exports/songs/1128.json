{
  "id" : 1128,
  "songNumber" : 150,
  "title" : "जयवंत मसीहा जयवंत हुआ है",
  "language" : "hindi",
  "originalKey" : "G",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "जयवंत मसीहा जयवंत हुआ है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 22
      } ]
    }, {
      "text" : "जयवंत सदा रहेगा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "शैतान के सिर को कुचला उसी ने",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 26
      } ]
    }, {
      "text" : "राज्य सदा वह करेगा।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "मृत्यु तेरा अब डंक कहां है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 24
      } ]
    }, {
      "text" : "कब्र तेरी अब जय कहां रही है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "तोडा प्रभु ने क्रूस की शक्ति से,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 29
      } ]
    }, {
      "text" : "जयवंत वह सब में होगा।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "यहूदा के गोत्र का सिंह भी वही है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 26
      } ]
    }, {
      "text" : "पुस्तक को खोलने जयवंत हुआ है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    }, {
      "text" : "सातों मुहरों को तोडने वाला है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 27
      } ]
    }, {
      "text" : "सब बातों में योग्य होगा।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "मंडली का सिर वही जो उस की देह है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 30
      } ]
    }, {
      "text" : "जी उठने वालों में पहलौठा वह है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "मृत्यु को उसने निगल लिया है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 25
      } ]
    }, {
      "text" : "प्रभु वह सबका होगा।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "सिंहासन के चारों ओर मेघधनुष है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 28
      } ]
    }, {
      "text" : "यशब माणिक मरकत की सी चमक है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "बीच में महान प्रभु विराजमान भी है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 31
      } ]
    }, {
      "text" : "जय जयकर उसका होगा।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 6",
    "lines" : [ {
      "text" : "चौबीस प्राचीन जिसके आगे झुके है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 29
      } ]
    }, {
      "text" : "चारों प्राणी सदा आमीन कहते है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "स्वर्ग में पृथ्वी पर और उसके नीचे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 29
      } ]
    }, {
      "text" : "सब का मालिक वह होगा।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 7",
    "lines" : [ {
      "text" : "ईश्वर की स्तुति हा प्रभु यीशु से,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 30
      } ]
    }, {
      "text" : "विजय हम को देता अपनी इच्छा से,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "जयवंत से बढकर हम उस के द्वारा है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 30
      } ]
    }, {
      "text" : "सब से अद्भुत वह होगा।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    } ]
  } ]
}