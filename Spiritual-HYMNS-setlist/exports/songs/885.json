{
  "id" : 885,
  "songNumber" : 273,
  "title" : "IS YOUR ALL ON THE ALTAR OF SACRIFICE LAID",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "You have longed for sweet peace,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "And for faith to increase,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 17
      } ]
    }, {
      "text" : "And have earnestly, fervently prayed,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "But you cannot have rest,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "Or be perfectly blest,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "Until all on the altar is laid.",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "A",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "Is your all on the altar of sacrifice laid ?",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 28
      }, {
        "chord" : "A",
        "position" : 38
      } ]
    }, {
      "text" : "Your heart does the Spirit control ?",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "You can only be blessed,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 13
      } ]
    }, {
      "text" : "And have peace and sweet rest",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "As you yield Him your body and soul.",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "Would you walk with the Lord",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "In the light of His Word,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 20
      } ]
    }, {
      "text" : "And have peace and contentment alway;",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "A",
        "position" : 33
      } ]
    }, {
      "text" : "You must do His sweet will,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "To be free from all ill;",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "On the altar your all you must lay.",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "Oh we never can know,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "What the Lord will bestow,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "Of the blessings for which we have prayed,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "A",
        "position" : 35
      } ]
    }, {
      "text" : "Till our body and soul,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "He doth fully control,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    }, {
      "text" : "And our all on the altar is laid.",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "Who can tell of the love,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "He will send from above,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 19
      } ]
    }, {
      "text" : "And how happy our hearts will be made,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 33
      } ]
    }, {
      "text" : "Of the fellowship sweet,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "We shall share at His feet,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "When our all on the altar is laid.",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    } ]
  } ]
}