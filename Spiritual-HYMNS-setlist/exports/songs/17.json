  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "प्रभू ख्रिस्ता कृपामय, मला तूंचि हो आश्रय;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 37
      } ]
    }, {
      "text" : "तूझी क्रूस खोचली, पाणी रक्त वाहिली,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 18
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "तेणे उद्धरी मला, पापें सोडी मंगला.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 17
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "जरी रडे अनिवार, जरी सुकृते अपार,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "येणे होईना उपाय, बूडतो तूझ्याशिवाय;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 17
      }, {
        "chord" : "G",
        "position" : 31
      } ]
    }, {
      "text" : "येशू ख्रिस्ता, मी लाचार, तूझ्या रक्ताने दे उद्धार."
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "जो मी श्वासा टाकितो, तो मी कृपा मागतो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 21
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    }, {
      "text" : "पुढे प्राण सोडीतां, तूजकडे चढतां,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "येशू ख्रिस्ता कृपामय, तुझ्या ठायी दे आश्रय.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    } ]
  } ]
}