        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 34
      } ]
    }, {
      "text" : "Thou hast put off my sack cloth",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 26
      } ]
    }, {
      "text" : "Thou hast turned my mourning into dancing for me"
    }, {
      "text" : "And girded me with gladness",
