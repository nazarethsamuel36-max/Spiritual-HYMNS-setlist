    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "All glory to God,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 13
      } ]
    }, {
      "text" : "He has lifted me up,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 17
      } ]
    }, {
      "text" : "He has lifted me up I know,",
