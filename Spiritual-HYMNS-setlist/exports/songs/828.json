        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "He stretched out His hand,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "And He lifted me up,",
