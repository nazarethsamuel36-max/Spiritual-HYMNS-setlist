  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Glory Jesus Glory",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 12
      } ]
    }, {
      "text" : "You do the fighting for me.",
      "chords" : [ {
        "chord" : "G",
        "position" : 11
      } ]
    }, {
      "text" : "Praise you Jesus, praise You,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "In You, there's always victory.",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 23
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Ye are of God little children",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "And have overcome them,",
      "chords" : [ {
        "chord" : "A",
        "position" : 9
      } ]
    }, {
      "text" : "For greater is He that is in You",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      } ]
    }, {
      "text" : "Than He that is in the world.",
      "chords" : [ {
        "chord" : "G",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 23
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Abide in Him little children,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "That when He shall appear,",
      "chords" : [ {
        "chord" : "A",
        "position" : 10
      } ]
    }, {
      "text" : "We shall be like Him",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      } ]
    }, {
      "text" : "When He shall appear in glory.",
      "chords" : [ {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    } ]
  } ]
