{
  "id" : 606,
  "songNumber" : 20,
  "title" : "कोण मित्र येशुवाणी, सारें ओझे वाहाया ? (What A Friend We Have In Jesus)",
  "language" : "marathi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "कोण मित्र येशुवाणी, सारें ओझे वाहाया ?",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "सर्व दुखें तो ऐकूनी, साह्य करि सोसावा;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 27
      }, {
        "chord" : "G",
        "position" : 35
      } ]
    }, {
      "text" : "त्याकडे कधी न जाता, आम्ही अवमानितो,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "C",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 30
      } ]
    }, {
      "text" : "शांति खरि हरवूनि, शोक किती करितो !",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "G",
        "position" : 30
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "मोह असले कि चिंता, काहि दिसे त्रासाया,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    }, {
      "text" : "धैर्य नच सुटू देतां, जा प्रभुला सांगाया,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 29
      }, {
        "chord" : "G",
        "position" : 37
      } ]
    }, {
      "text" : "सर्व दुबळ्यांस पाहे, चित्तवृत्ति जाणतो,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "C",
        "position" : 21
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    }, {
      "text" : "मित्र प्रिय जसा आहे, 'हात धरि,' म्हणतो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "कष्टि जरि श्रमेलेले, खांब जड वहाया,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "त्यासहि उपाय केले, जा प्रभुला सांगाया;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 27
      }, {
        "chord" : "G",
        "position" : 35
      } ]
    }, {
      "text" : "मित्र जरि तुच्छ मानी, जा प्रभुला सांगाया;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 10
      }, {
        "chord" : "C",
        "position" : 22
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    }, {
      "text" : "तोचि सखा सर्वांहूनि, सिद्ध अंगिकाराया.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 27
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    } ]
  } ]
}