    "label" : "Verse 2",
    "lines" : [ {
      "text" : "Yogyata se badh ke diya"
    }, {
      "text" : "Hai apni daya se tune mujhe...2"
    }, {
      "text" : "Mangne se jyada mila mujhe"
    }, {
      "text" : "Aabhari hoon prabhu main...2"
    } ]
  }, {
