    "lines" : [ {
      "text" : "Dhanyawad ke saath stuti gaunga"
    }, {
      "text" : "Hey Yeshu mere khuda"
    }, {
      "text" : "Upkar tere hai beshumar"
    }, {
      "text" : "Koti koti stuti dhanyawad"
    }, {
      "text" : "..Repeat"
