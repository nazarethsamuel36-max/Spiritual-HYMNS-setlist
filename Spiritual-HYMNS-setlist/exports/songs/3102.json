    "label" : "Verse 3",
    "lines" : [ {
      "text" : "Tu hai saccha zinda khuda"
    }, {
      "text" : "Tujh par hi bharosa mera...2"
    }, {
      "text" : "Sewa poori karke paaon inaam"
    }, {
      "text" : "Prabhu aisa do vardan...2"
    } ]
