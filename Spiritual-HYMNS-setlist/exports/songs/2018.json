  "title" : "यीशु, यीशु तू सबसे है महान",
  "language" : "hindi",
  "originalKey" : "C",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "तू भलाई बिना, कुछ करता नहीं"
    }, {
      "text" : "सब बुराई मिटानेवाले"
    }, {
      "text" : "सारे पाप क्षमा करनेवाले"
    }, {
      "text" : "नया जीवन मुझे देनेवाले"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "यीशु,यीशु, तू सबसे है महान यीशु,"
    }, {
      "text" : "यीशु, खुश रहती तुझ में ये जान"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "करता हूँ जब तुझे प्यार"
    }, {
      "text" : "भलाई में बदले हर हाल"
    }, {
      "text" : "मानता हूँ जब तेरी बात"
    }, {
      "text" : "आशीषों का होता अम्बार"
    }, {
      "text" : "बढ़ता है फज़ल, मिलता तेरा बल"
    }, {
      "text" : "मीठे बनते, सारे कटु पल"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "छाता है जब अन्धकार"
    }, {
      "text" : "रोशनी का तू , बनता मीनार"
    }, {
      "text" : "रोग से होता लाचार"
    }, {
      "text" : "चंगा करता तेरा कलाम"
    }, {
      "text" : "मेरे जीवन में, स्वर्गीय आशीषें"
    }, {
      "text" : "नित्य भरता, है तू हर पल"
    } ]
  } ]
}