{
  "id" : 1106,
  "songNumber" : 128,
  "title" : "मसिह ने मेरे लिए क्या किया",
  "language" : "hindi",
  "originalKey" : "G",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "मसिह ने मेरे लिए क्या किया ?",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "पुछो मुझसे मैं गवाही दूँगा",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "यीशु है कौन मुझ से पुछो",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "गा के बताऊँगा गीतो में ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "जीवीत खुदावंद का वह पुत्र मसिहा है",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "वचन जो देहधारी हुआ, सिरजनहार है वो,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "पापियों के लिए मर के उठा, अनंत जीवन वह",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "महिमा को छोडकर उतर आया, मसिह ने ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "ज्योति बनकर आया मसिह खोज के पाया",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "मुझे राज्य का सुसमाचार मुझ को सुनाया है वह,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "अपने ही खून से धोया है, मेरे पापों को वह",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "मौत से मुझको बचाने को आया मसिहा दुनिया में ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 39
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "शरीर में वह परगट हुआ, आत्मा से धर्मी ठहरा",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "अल्फा और ओमेगा है, आदि और अंत है वह",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "हम को दुल्हन बनाकर, दुल्हा बन गया वह",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "जल्दी आने को कह गया वह",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "जल्दी आयेगा मसिहा मेरा।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    } ]
  } ]
}