        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 19
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    }, {
      "text" : "समय पूरा होने पर वह साथ ले जाएगा ।",
