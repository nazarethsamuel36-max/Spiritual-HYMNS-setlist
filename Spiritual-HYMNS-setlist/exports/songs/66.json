  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "खुशी ही खुशी है, खुशी ही खुशी है",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 17
      }, {
        "chord" : "G",
        "position" : 30
      } ]
    }, {
      "text" : "खुशी है मन में मेरे ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "यीशु ने बचा लिया, नया जन्म दे दिया",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 18
      }, {
        "chord" : "G",
        "position" : 32
      } ]
    }, {
      "text" : "खुशी है मन में मेरे ।"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "रास्ते को छोडकर मैं अपने पापों को लिए फिरा (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 40
      } ]
    }, {
      "text" : "प्यार से यीशु ने लिया, ले लिया बोझ मेरा (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 37
      } ]
    }, {
      "text" : "तोबा मैंने पापों से अब मन फिरा लिया ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "शत्रु का सामना मैं वचन से कर लूंगा (2)",
