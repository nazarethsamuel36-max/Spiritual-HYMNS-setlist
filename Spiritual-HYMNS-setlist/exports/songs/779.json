{
  "id" : 779,
  "songNumber" : 167,
  "title" : "THE LOVE OF GOD",
  "language" : "english",
  "originalKey" : "F",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "The love of God is greater far",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "Than tongue or pen can ever tell;",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 23
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "It goes beyond the highest star,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "And reaches to the lowest hell.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    }, {
      "text" : "The guilty pair, bowed down with care,",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "God gave His son to win;",
      "chords" : [ {
        "chord" : "A",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "His erring child He reconciled,",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "And pardoned from his sin.",
      "chords" : [ {
        "chord" : "A",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "Chorus",
    "lines" : [ {
      "text" : "Oh, love of God, how rich and pure !",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "How measureless and strong !",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 20
      } ]
    }, {
      "text" : "It shall forevermore endure,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "The saints and angels song.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "When hoary time shall pass away,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "And earthly thrones and kingdoms fall;",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 24
      }, {
        "chord" : "D",
        "position" : 33
      } ]
    }, {
      "text" : "When men who here refuse to pray,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "On rocks and hill and mountains call;",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    }, {
      "text" : "God's love, so sure, shall still endure,",
      "chords" : [ {
        "chord" : "G",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "All measureless and strong;",
      "chords" : [ {
        "chord" : "A",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "Redeeming grace to Adam's race,",
      "chords" : [ {
        "chord" : "G",
        "position" : 2
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "The saints' and angels' song.",
      "chords" : [ {
        "chord" : "A",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "Could we with ink the ocean fill,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "And were the skies of parchment made;",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    }, {
      "text" : "Were every stalk on earth a quill,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "And every man a scribe by trade,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    }, {
      "text" : "To write the love of God above",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "Would drain the ocean dry;",
      "chords" : [ {
        "chord" : "A",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "Nor could the scroll contain the whole,",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    }, {
      "text" : "Though stretched from sky to sky.",
      "chords" : [ {
        "chord" : "A",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    } ]
  } ]
}