  "title" : "** All I Once Held Dear",
  "language" : "english",
  "originalKey" : "** C",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "SECTIONS",
    "lines" : [ ]
  }, {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "All I once held dear, built my life upon"
    }, {
      "text" : "All this world reveres, and wars to own"
    }, {
      "text" : "All I once thought gain I have counted loss"
    }, {
      "text" : "Spent and worthless now, compared to this"
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "Knowing you, Jesus, knowing you,"
    }, {
      "text" : "There is no greater thing"
    }, {
      "text" : "You're my all, you're the best"
    }, {
      "text" : "You're my joy, my righteousness"
    }, {
      "text" : "And I love you, Lord"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "Now my heart's desire is to know you more"
    }, {
      "text" : "To be found in you and known as yours"
    }, {
      "text" : "To possess by faith what I could not earn"
    }, {
      "text" : "All-surpassing gift of righteousness"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "Oh, to know the power of your risen life"
    }, {
      "text" : "And to know You in Your sufferings"
    }, {
      "text" : "To become like you in your death, my Lord"
    }, {
      "text" : "So with you to live and never die"
    } ]
  } ]
}