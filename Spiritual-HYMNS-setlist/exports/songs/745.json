{
  "id" : 745,
  "songNumber" : 133,
  "title" : "ONWARD CHRISTIAN SOLDIERS",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Onward, Christian soldiers !",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Marching as to war,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "With the cross of Jesus",
      "chords" : [ {
        "chord" : "A",
        "position" : 9
      } ]
    }, {
      "text" : "Going on before;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 11
      } ]
    }, {
      "text" : "Christ, the royal Master,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Leads against the foe;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "Forward into battle,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "See, His banners go !",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Onward, Christian soldiers !"
    }, {
      "text" : "Marching as to war,"
    }, {
      "text" : "With the cross of Jesus"
    }, {
      "text" : "Going on before.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 11
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Like a mighty army",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "Moves the Church of God;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "Brothers, we are treading",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Where the saints have trod;",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "We are not divided,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "All one body we;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "One in hope and doctrine,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "One in charity.",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 10
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Crowns and thrones may perish,",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      } ]
    }, {
      "text" : "Kingdoms rise and wane;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "But the Church of Jesus",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      } ]
    }, {
      "text" : "Constant will remain;",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "Gates of hell can never",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "'Gainst that Church prevail;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "We have Christ's own promise,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      } ]
    }, {
      "text" : "Which can never fail.",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "At the name of Jesus,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "Satan's host doth flee;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "Oh, then, Christian soldiers,",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      } ]
    }, {
      "text" : "On to victory !",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 9
      } ]
    }, {
      "text" : "Hell's foundations quiver",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      } ]
    }, {
      "text" : "At the shout of praise;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "Brothers, lift your voices,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Loud your anthems raise !",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Onward, then, ye people !",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      } ]
    }, {
      "text" : "Join our happy throng;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "Blend with ours your voices",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      } ]
    }, {
      "text" : "In the triumph song;",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "Glory, laud, and honour,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Unto Christ the King;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "This through countless ages",
      "chords" : [ {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "Men and angels sing.",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    } ]
  } ]
}