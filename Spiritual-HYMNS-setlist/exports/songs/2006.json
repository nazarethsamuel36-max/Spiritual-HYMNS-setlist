  "title" : "हाल्लेलुयाह, हाल्लेलुयाह, हम गाते है बारंबार",
  "language" : "hindi",
  "originalKey" : "F",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "हाल्लेलुयाह (2) हम गाते है बारंबार"
    }, {
      "text" : "धन्यवाद यीशु तुझको, तुने किया है हम से प्यार (2)"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "तेरे चरणों में आते है और आशिष चाहते है"
    }, {
      "text" : "अपनी आँखों को यीशु हम तुझपे लगाते है"
    }, {
      "text" : "हाल्लेलुयाह (2) हम करे तेरा इंतजार।"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "तेरे चरणों में आते है और लिन हो जाते है"
    }, {
      "text" : "ये जीवन हे प्रभु यीशु तुझे अर्पण करते है"
    }, {
      "text" : "हाल्लेलुयाह (2) ये जीवन तुझपे निसार।"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "हम शीष झुकाते है हाथों को उठाते है"
    }, {
      "text" : "और ऊँचे स्वर से यीशु तेरी महिमा करते है"
    }, {
      "text" : "हाल्लेलुयाह (2) हम गाते है बारंबार (2)"
    } ]
  } ]
}