    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "We are here to praise You",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Lift our hearts and sing,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "We are here to give You,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "The best that we can bring.",
      "chords" : [ {
        "chord" : "E",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "And it is our love,",
      "chords" : [ {
        "chord" : "G",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "Rising from our hearts",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "Everything within us cries \"Abba Father\"",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      }, {
        "chord" : "A",
        "position" : 28
      } ]
    }, {
      "text" : "Help us now to give You",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Pleasure and delight,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "Heart and mind and will that say,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "\"I love You, Lord\".",
      "chords" : [ {
