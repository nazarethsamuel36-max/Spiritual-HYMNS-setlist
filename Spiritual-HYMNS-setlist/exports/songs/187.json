        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "A",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
