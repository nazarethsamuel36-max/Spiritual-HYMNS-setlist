        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 28
      } ]
    }, {
      "text" : "His glorious presence, His words of welcome,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    }, {
      "text" : "Will be my portion on that fair shore.",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    } ]
  }, {
