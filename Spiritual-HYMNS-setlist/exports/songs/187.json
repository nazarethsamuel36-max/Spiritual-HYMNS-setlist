        "chord" : "D",
        "position" : 15
      }, {
        "chord" : "A",
        "position" : 36
      } ]
    }, {
      "text" : "O day of gladness, O day unending ;",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "Beyond the sunset, eternal joy.",
