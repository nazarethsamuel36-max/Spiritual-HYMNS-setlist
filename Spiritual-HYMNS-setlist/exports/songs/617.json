        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 41
      } ]
    }, {
      "text" : "Called to live in the Word and be free to live for others;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 42
      } ]
