{
  "id" : 844,
  "songNumber" : 232,
  "title" : "THE SAVIOUR IS WAITING",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "The Saviour is waiting to enter your heart.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 26
      }, {
        "chord" : "D",
        "position" : 37
      } ]
    }, {
      "text" : "Why don't you let Him come in?",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    }, {
      "text" : "There's nothing in this world to keep you apart;",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 33
      }, {
        "chord" : "D",
        "position" : 43
      } ]
    }, {
      "text" : "What is your answer to Him?",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "Time after time He has waited before,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "And now He is waiting again,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 23
      } ]
    }, {
      "text" : "To see if you're willing to open the door,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "Oh, how He wants to come in!",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "If you'll take one step t'wards the Saviour, my friend,",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 36
      }, {
        "chord" : "D",
        "position" : 48
      } ]
    }, {
      "text" : "You'll find His arms open wide.",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 26
      } ]
    }, {
      "text" : "Receive Him and all of your darkness will end,",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "G",
        "position" : 28
      }, {
        "chord" : "D",
        "position" : 42
      } ]
    }, {
      "text" : "Within your heart He'll abide.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    } ]
  } ]
}