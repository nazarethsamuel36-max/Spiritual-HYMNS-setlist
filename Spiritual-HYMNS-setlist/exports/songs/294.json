        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "I know that He will be there,",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "A",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "With His crook and with His staff.",
