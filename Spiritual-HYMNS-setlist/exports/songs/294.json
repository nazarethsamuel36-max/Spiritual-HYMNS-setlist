  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "He guides me along,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    }, {
      "text" : "For He knows to be right,",
      "chords" : [ {
        "chord" : "G",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "If I walk in the darkness,",
      "chords" : [ {
        "chord" : "G",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    }, {
      "text" : "No evil would I fear,",
