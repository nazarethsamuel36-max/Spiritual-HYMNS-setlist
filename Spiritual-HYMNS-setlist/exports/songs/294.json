        "chord" : "G",
        "position" : 9
      }, {
        "chord" : "A",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
