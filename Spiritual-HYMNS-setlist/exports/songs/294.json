        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "Where He gives me repose,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 9
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "Near restful waters He leads me,",
      "chords" : [ {
        "chord" : "G",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "To revive my drooping spirit.",
      "chords" : [ {
        "chord" : "G",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    } ]
