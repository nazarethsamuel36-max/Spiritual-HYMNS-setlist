  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "The Lord is my Shepherd,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "There is nothing I shall want,",
      "chords" : [ {
        "chord" : "G",
        "position" : 9
      }, {
        "chord" : "A",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "Fresh and green are the pastures,",
