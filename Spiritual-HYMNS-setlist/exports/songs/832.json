        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 27
      }, {
        "chord" : "A",
        "position" : 39
      }, {
        "chord" : "D",
        "position" : 44
      } ]
    }, {
      "text" : "Let me be singing when the evening comes.",
