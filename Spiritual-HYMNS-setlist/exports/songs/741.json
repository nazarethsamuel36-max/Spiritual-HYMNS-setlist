{
  "id" : 741,
  "songNumber" : 129,
  "title" : "MARVELOUS GRACE",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Marvelous grace of our loving Lord,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Grace that exceeds our sin and our guilt.",
      "chords" : [ {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    }, {
      "text" : "Yonder on Calvary's mount outpoured,",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "A",
        "position" : 29
      } ]
    }, {
      "text" : "There where the Blood of the Lamb was spilt.",
      "chords" : [ {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Grace, grace, God's grace,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "Grace that will pardon and cleanse within;",
      "chords" : [ {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 39
      } ]
    }, {
      "text" : "Grace, grace, God's grace,"
    }, {
      "text" : "Grace that is greater than all our sin.",
      "chords" : [ {
        "chord" : "A",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Sin and despair like the sea waves cold,",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      } ]
    }, {
      "text" : "Threaten the soul with infinite loss;",
      "chords" : [ {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    }, {
      "text" : "Grace that is greater, yes, grace untold,",
      "chords" : [ {
        "chord" : "D",
        "position" : 14
      }, {
        "chord" : "A",
        "position" : 36
      } ]
    }, {
      "text" : "Points to the Refuge, the Mighty Cross.",
      "chords" : [ {
        "chord" : "D",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Dark is the stain that we cannot hide,",
      "chords" : [ {
        "chord" : "D",
        "position" : 12
      } ]
    }, {
      "text" : "What can avail to wash it away?",
      "chords" : [ {
        "chord" : "G",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "Look! there is flowing a crimson tide;",
      "chords" : [ {
        "chord" : "D",
        "position" : 15
      }, {
        "chord" : "A",
        "position" : 33
      } ]
    }, {
      "text" : "Whiter than snow you may be today.",
      "chords" : [ {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 30
      } ]
    }, {
      "text" : "Marvelous, infinite, matchless grace,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 31
      } ]
    }, {
      "text" : "Freely bestowed on all who believe,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    }, {
      "text" : "You that are longing to see His face,",
      "chords" : [ {
        "chord" : "D",
        "position" : 13
      }, {
        "chord" : "A",
        "position" : 32
      } ]
    }, {
      "text" : "Will you this moment His grace receive?",
      "chords" : [ {
        "chord" : "D",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    } ]
  } ]
}