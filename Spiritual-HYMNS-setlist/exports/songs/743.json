{
  "id" : 743,
  "songNumber" : 131,
  "title" : "SEARCH ME O GOD",
  "language" : "english",
  "originalKey" : "D",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Search me, O God, and know my heart today;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 30
      }, {
        "chord" : "D",
        "position" : 38
      } ]
    }, {
      "text" : "Try me, O Saviour, know my thoughts, I pray;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    }, {
      "text" : "See if there be some wicked way in me;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    }, {
      "text" : "Cleanse me from every sin, and set me free.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 38
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "I praise Thee, Lord, for cleansing me from sin;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 35
      }, {
        "chord" : "D",
        "position" : 43
      } ]
    }, {
      "text" : "Fulfill Thy Word, and make me pure within;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "Fill me with fire, where once I burned with shame;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 32
      }, {
        "chord" : "D",
        "position" : 44
      } ]
    }, {
      "text" : "Grant my desire to magnify Thy Name.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Lord, take my life, and make it wholly Thine;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 32
      }, {
        "chord" : "D",
        "position" : 39
      } ]
    }, {
      "text" : "Fill my poor heart with Thy great love divine;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 34
      } ]
    }, {
      "text" : "Take all my will, my passion, self and pride;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 30
      }, {
        "chord" : "D",
        "position" : 39
      } ]
    }, {
      "text" : "I now surrender; Lord, in me abide.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 26
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "O Holy Ghost, revival comes from Thee;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 33
      } ]
    }, {
      "text" : "Send a revival, start the work in me;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 26
      } ]
    }, {
      "text" : "Thy Word declares Thou wilt supply our need;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 28
      }, {
        "chord" : "D",
        "position" : 39
      } ]
    }, {
      "text" : "For blessing now, O Lord, I humbly plead.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 28
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    } ]
  } ]
}