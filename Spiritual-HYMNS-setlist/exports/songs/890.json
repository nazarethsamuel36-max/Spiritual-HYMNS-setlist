        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "And I shall be whiter than snow.",
      "chords" : [ {
