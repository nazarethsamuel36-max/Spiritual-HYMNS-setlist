        "position" : 8
      }, {
        "chord" : "A",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "Grievous were the sorrows He bore",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    }, {
