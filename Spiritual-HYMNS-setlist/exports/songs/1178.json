    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "मैं आता हूँ तेरे पास, प्रभु यीशु मेरे मसीह",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 22
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    }, {
      "text" : "मेरे पापों के लिए ही, उद्धार दे दे मसीह ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "स्वर्ग धाम तू छोड़ के आया, उद्धार देने मसीह,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 22
      }, {
        "chord" : "G",
        "position" : 39
      } ]
    }, {
      "text" : "चरणों में तेरे आता, तुझको दिल देता मसीह ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    }, {
      "text" : "मुझे पापों से छुड़ाने, लहू क्रूसपर बहा दिया,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    }, {
      "text" : "कितना गहरा प्यार किया है, मैं भुला न सकूँगा मसीह ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "G",
        "position" : 45
      } ]
    }, {
      "text" : "स्वीकार कर प्रभु मुझे, अपने राज्य में ले ले,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 19
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    }, {
      "text" : "आ जा तू मेरी जिंदगी में, मेरी जिंदगी तेरी मसीह ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 43
      } ]
    } ]
  } ]
}