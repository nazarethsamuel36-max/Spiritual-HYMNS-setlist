  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "हे प्रभु यीशु इन दोनों पर"
    }, {
      "text" : "अपनी आशीषें बरसा"
    }, {
      "text" : "की सुखी रहे ये जीवन भर"
    }, {
      "text" : "और रहे प्रेम से सदा ।"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "जीवन की राहो मे काटे जो आए"
    }, {
      "text" : "यीशु तू इनको हटा"
    }, {
      "text" : "बादल दुखो के घीर घीर जो आए"
    }, {
      "text" : "आशा के किरने चमका ।"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "होवे ये ऐसा मसीह घराना"
    }, {
      "text" : "जिसका तू मालिक रहे"
    }, {
      "text" : "दिल होवे तेरे, प्रेम का खजाना"
    }, {
      "text" : "जिसका तू मालिक रहे ।"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "आपस के प्रेम में बंधे रहे ये"
    }, {
      "text" : "जब तक तू आए प्रभु"
    }, {
      "text" : "महिमा तेरी गाते रहे ये"
    }, {
      "text" : "जब तक तू आए प्रभु |"
    } ]
  } ]
}