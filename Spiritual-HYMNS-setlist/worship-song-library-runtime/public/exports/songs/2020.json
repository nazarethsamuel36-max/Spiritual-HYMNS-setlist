  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "मेरे छोटे हृदय से, मेरे महान प्रभु की"
    }, {
      "text" : "आराधना करूँ"
    }, {
      "text" : "टूटे हुए कुंड को"
    }, {
      "text" : "मेरे कुंभार के पास लाकर"
    }, {
      "text" : "ठीक करने की विनती करूँ |"
    } ]
  }, {
    "type" : "chorus",
    "label" : "Chorus",
    "lines" : [ {
      "text" : "CHORUS:"
    }, {
      "text" : "हो---सन्ना, हो---सन्ना..... यहूदियों के राजा को |"
    }, {
      "text" : "हो---सन्ना, हो---सन्ना.....आनेवाले राजा को |"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "मिट्टी से बनाया गया हूँ,"
    }, {
      "text" : "फिर मिट्टी में जा मिलूँ....२"
    }, {
      "text" : "मुझ मिट्टी को, महिमा में बदलने,"
    }, {
      "text" : "तेरे महिमा को त्याग दिया....२"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "कदम लड़खड़ाते समय में,"
    }, {
      "text" : "तेरी कृपाने संभाला मुझे....२"
    }, {
      "text" : "मेरे कदम सिद्ध करके, तेरी सेवामें,"
    }, {
      "text" : "कृपा से चलाया मुझे....२"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "इस संसार की यात्रा में,"
    }, {
      "text" : "मेरे जीवन की सपना है....२"
    }, {
      "text" : "मेरे अंतिम स्वास, जाने तक,"
    }, {
      "text" : "तेरे नाम की महिमा करूँ....२"
    } ]
  } ]
}