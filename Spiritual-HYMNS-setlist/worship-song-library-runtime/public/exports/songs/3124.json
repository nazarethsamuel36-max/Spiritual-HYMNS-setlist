  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "हमको मिला है ये जिंदगी जो"
    }, {
      "text" : "जीना है सिर्फ एक बार"
    }, {
      "text" : "फिर ना मिलेगी, फिर ना आयेगी"
    }, {
      "text" : "जीवन की ये घडिया |"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "जिवन के हर एक पलपल में"
    }, {
      "text" : "देखो कितने इन्तेहाल"
    }, {
      "text" : "ना समझे एसे में हम"
    }, {
      "text" : "कब और कहा मुड़ जाये"
    }, {
      "text" : "तेरा वचन है उजियाला हमको"
    }, {
      "text" : "जीवन की राह दिखाए |"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "कहता है यीशु हम दिनों को"
    }, {
      "text" : "मैं हु पथ सत्य, जीवन"
    }, {
      "text" : "जो कोई मेरे संग हो लिएगा"
    }, {
      "text" : "नया जीवन पायेगा"
    }, {
      "text" : "तेरा वचन है उजियाला हमको"
    }, {
      "text" : "जीवन की राह दिखाए |"
    } ]
  } ]
}