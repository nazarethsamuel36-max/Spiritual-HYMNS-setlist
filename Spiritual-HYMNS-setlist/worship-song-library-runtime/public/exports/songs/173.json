      }, {
        "chord" : "G",
        "position" : 37
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "मुर्दों को जिसने जिंदा भी किया, वो यीशु प्यारा है",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 26
      } ]
    }, {
      "text" : "रोगियों को जिसने चंगा भी किया, वो यीशु मेरा है",
