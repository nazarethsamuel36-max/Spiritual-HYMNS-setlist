        "chord" : "C",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 45
      } ]
    }, {
      "text" : "यीशु मसीह संग हमको बिठाने, वारिस बनाया है।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 36
      }, {
        "chord" : "G",
        "position" : 39
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "क्या वर्तमान और क्या भविष्य, सब कुछ हमारा है",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 21
      } ]
    }, {
      "text" : "सौ गुणा प्रतिफल यहां पर, स्वर्ग में अनंत जीवन है",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 41
      } ]
    }, {
      "text" : "यीशु मसी में इस जीवन को, यह धन्य आशा है।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "D",
