        "position" : 18
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "यीशु मसीह में स्वर्गीय स्थानों में, सब आषिषे हमे दी",
      "chords" : [ {
        "chord" : "G",
