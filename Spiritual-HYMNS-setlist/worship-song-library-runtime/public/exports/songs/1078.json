{
  "id" : 1078,
  "songNumber" : 100,
  "title" : "अंबर भी नया, धरती भी नयी और",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "अंबर भी नया, धरती भी नयी और",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      } ]
    }, {
      "text" : "नया यरुशलेम होगा ।",
      "chords" : [ {
        "chord" : "Bb",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 14
      } ]
    }, {
      "text" : "हर सुबह नयी, हर शाम नयी,",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      } ]
    }, {
      "text" : "हर वक्त सुहाना होगा ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 17
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "अंधे की आँख खुलेंगी, बहिरे का कान खुलेगा ।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      } ]
    }, {
      "text" : "दौडेगा जोर से लंगडा, गुंगा भी महिमा गाएगा ।",
      "chords" : [ {
        "chord" : "Bb",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 21
      }, {
        "chord" : "F",
        "position" : 39
      } ]
    }, {
      "text" : "कष्ट नहीं, आसू भी नहीं, बस प्यार ही प्यार होगा ।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 24
      }, {
        "chord" : "F",
        "position" : 44
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "सूरज भी न डूबेगा, चाँद भी ना सोयेगा,",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      } ]
    }, {
      "text" : "कभी अंधेरा न होगा, ना पाप का नाम ना होगा,",
      "chords" : [ {
        "chord" : "Bb",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 19
      }, {
        "chord" : "F",
        "position" : 38
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "वहाँ मौत नहीं, बिमारी नहीं",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      } ]
    }, {
      "text" : "दुःख का अन्त होगा ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 15
      } ]
    } ]
  } ]
}