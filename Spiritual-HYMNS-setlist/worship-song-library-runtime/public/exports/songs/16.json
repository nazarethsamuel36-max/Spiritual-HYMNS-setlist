        "position" : 22
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "वंदा, वंदा तारक प्रभु येशूला !"
    }, {
      "text" : "गा, हे पृथ्वी, अतुल ती प्रीती;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "वंदा, वंदा, स्वर्गीय दूत, तयाला,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "द्या हो नामा, महिमा त्या अती !",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "मेंढपाळासम रक्षी आम्हांला,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "स्वहस्तीं तो नेहमी धरुनी.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "वंदा, वंदा तयाचि कीर्ती सांगूनी",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "वंदा, वंदा हर्षानें गाउनी !",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "साही दु:खे, मरण, पावास्तव;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "तोची आहे सतत तारण आशा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 10
      } ]
    }, {
      "text" : "वंदा, वंदा येशू उद्धारास्तव !",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "गेलें पाप, करा, करा, प्रशंसा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "प्रीती त्याची अमित पाहुनी.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "आकाशांनो, जयकारा करा !",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "राज्य सार्वकालिक मिळे येशूला.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "घाला, घाला मुगुट त्या शिरा !",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "येशू येई विजयि या जगाला,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 11
      } ]
    }, {
      "text" : "शक्ती, कीर्ती जाइ तें व्यापुनी !",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    } ]
  } ]
}