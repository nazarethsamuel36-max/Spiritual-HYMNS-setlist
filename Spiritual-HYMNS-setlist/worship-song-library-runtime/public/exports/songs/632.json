{
  "id" : 632,
  "songNumber" : 325,
  "title" : "STANDING BY A PURPOSE TRUE",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Standing by a purpose true,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : "Heeding God's command,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    }, {
      "text" : "Honor them, the faithful few!",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "All hail to Daniel's band!",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "Dare to be a Daniel,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Dare to stand alone!",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "Dare to have a purpose firm!",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "Dare to make it known.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "Many mighty men are lost",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 12
      } ]
    }, {
      "text" : "Daring not to stand,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "Who for God had been a host",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "By joining Daniel's band.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "Many giants, great and tall,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : "Stalking through the land,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "Headlong to the earth would fall,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "If met by Daniel's band.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "Hold the Gospel banner high!",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 16
      } ]
    }, {
      "text" : "On to vict'ry grand!",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "Satan and his hosts defy,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    }, {
      "text" : "And shout for Daniel's band.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    } ]
  } ]
}