      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    }, {
      "text" : "Guilt is gone, peace is mine, peace like to a river,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 30
      } ]
    }, {
      "text" : "Jesus is wonderful mighty to deliver.",
