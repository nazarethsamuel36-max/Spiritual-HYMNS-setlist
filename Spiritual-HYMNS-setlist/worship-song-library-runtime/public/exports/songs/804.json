        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 37
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
