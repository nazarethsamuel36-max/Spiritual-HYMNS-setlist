        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 39
      } ]
    }, {
      "text" : "Wonderful is my Redeemer, praise His name!",
