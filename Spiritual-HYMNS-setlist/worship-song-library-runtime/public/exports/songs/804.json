        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 20
      } ]
    }, {
      "text" : "Now the sins of the past have been all forgiven,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 30
      } ]
    }, {
      "text" : "And my name is inscribed on the book of heaven.",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 32
      }, {
