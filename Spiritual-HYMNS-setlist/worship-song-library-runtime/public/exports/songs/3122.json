    "label" : "Verse 1",
    "lines" : [ {
      "text" : "आराधनायेशु तुझे , आराधना येशु तुझे ,"
    }, {
      "text" : "आराधनायेशु तुझे , आराधना येशु तुझे"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "तु जो कहे दे में करूंगा"
    }, {
      "text" : "तेरी राहो पर में चलूंगा"
    }, {
      "text" : "तेरे चरनो में ही रहूंगा ,"
    }, {
      "text" : "मेरे प्यारे येशुवे"
    }, {
      "text" : ".....REPEAT"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "अद्भुत तेरे पैर जो , लहेरो पर चले"
    }, {
      "text" : "आगें चलते हे मेरे , मुझे चिंता नहीं है"
    }, {
      "text" : "डांटा आंधिओंको , जिन वचनो से प्रभु"
    }, {
      "text" : "साथी मेरे है वही , मुझे चिंता नहीं है"
    }, {
      "text" : ".....REPEAT"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "राहों को अंधेरोने , जब घेरा हो मेरे"
    }, {
      "text" : "प्रभु मुझको ले चले , मुझे डर ही नहीं है"
    }, {
      "text" : "फिरोन की सेना जब मेरे , पीछे हो पडी"
    }, {
      "text" : "है बचाता येशु मुझको , डर ही नहीं है"
    }, {
      "text" : ".....REPEAT"
    } ]
  } ]
}