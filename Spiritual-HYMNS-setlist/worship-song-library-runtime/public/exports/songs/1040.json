        "position" : 36
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "जैसे तेरी मर्जी आसमान में पूरी होती,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
