        "chord" : "D",
        "position" : 17
      }, {
        "chord" : "E",
        "position" : 30
      }, {
        "chord" : "A",
        "position" : 32
      } ]
    }, {
      "text" : "उसी तरह हमारे अपराधों को माफ़ कर दे ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "E",
        "position" : 25
      }, {
        "chord" : "D",
        "position" : 29
