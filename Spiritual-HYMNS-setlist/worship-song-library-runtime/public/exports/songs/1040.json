        "position" : 0
      }, {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "A",
        "position" : 28
      } ]
    }, {
      "text" : "तेरा नाम पाक माना जाए, तेरी बादशाहत आए।",
      "chords" : [ {
        "chord" : "E",
        "position" : 0
