        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "E",
        "position" : 26
      }, {
        "chord" : "A",
        "position" : 33
      } ]
    }, {
      "text" : "वैसे ही तेरी मर्जी जगत में पूरी हो जाए ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      }, {
        "chord" : "E",
        "position" : 27
      }, {
        "chord" : "D",
        "position" : 32
      }, {
        "chord" : "A",
        "position" : 37
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "रोज की रोटी हमारी आज हमको दे दे,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "E",
        "position" : 21
      }, {
        "chord" : "A",
        "position" : 29
      } ]
    }, {
      "text" : "जीवन की रोटी तू है तू ही हमारा बल है ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      }, {
        "chord" : "E",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 26
      }, {
        "chord" : "A",
        "position" : 34
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "जिस तरह हम अपने अपराधी को माफ़ करते,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
