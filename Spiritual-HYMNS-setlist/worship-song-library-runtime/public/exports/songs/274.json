  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "I'd rather have Jesus than silver or gold,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "I'd rather be His than have riches untold,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 28
      }, {
        "chord" : "A",
        "position" : 37
      } ]
    }, {
      "text" : "I'd rather have Jesus than houses or lands,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "I'd rather be led by His nail-pierced hands.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "A",
        "position" : 25
      }, {
        "chord" : "D",
        "position" : 38
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "Than to be the king of a vast domain",
      "chords" : [ {
        "chord" : "A",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "And be held in sin's dread sway.",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 15
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    }, {
      "text" : "I'd rather have Jesus than anything",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "That this world can afford to pay.",
      "chords" : [ {
        "chord" : "A",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "He's fairer than lilies of rarest bloom,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "He's sweeter than honey from out of the comb,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 29
      }, {
        "chord" : "A",
        "position" : 40
      } ]
    }, {
      "text" : "He's all that my hungering spirit needs,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "I'd rather have Jesus and let Him lead.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "A",
        "position" : 26
      }, {
        "chord" : "D",
        "position" : 34
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
