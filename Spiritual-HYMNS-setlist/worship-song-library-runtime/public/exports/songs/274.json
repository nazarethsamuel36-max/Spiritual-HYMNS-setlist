        "position" : 4
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "I'd rather be faithful to His dear cause,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 26
      }, {
        "chord" : "A",
        "position" : 35
      } ]
    }, {
