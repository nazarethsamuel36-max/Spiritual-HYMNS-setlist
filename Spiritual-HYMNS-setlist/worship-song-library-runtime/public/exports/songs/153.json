  "title" : "SABNE GUNAHGAR KO",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "सबने गुनहगार को, नजरों से जब गिरा दिया",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    }, {
      "text" : "तूने मसीह मेहरबां, अपने गले लगा लिया।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "देखा गया न आपसे, कि मैं गुनाह में मरुं",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    }, {
      "text" : "जकडा हुआ गुनाहों में, दुनिया में मैं यूं फिरूं",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "मेरी नजात के लिए, खूने जिगर बहा दिया।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 18
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "मुझसे गुनहगार की, लेकर बलायें आपने",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "दुनिया में प्यार का सिला, सबको सिखाया आपने",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "दाग-ए-गुनाह धो दिये, बारे गुनाह उठा लिए।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 21
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "आसी-ए-नामुराद को, बख्शी है जिंदगी नई",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "उसके गुनाह भी धो दिए, बख्शी उसे भी जिंदगी",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "दिल को गुनहगार के, खाना-ए-खुदा बना दिया।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 19
      } ]
    } ]
  } ]
}