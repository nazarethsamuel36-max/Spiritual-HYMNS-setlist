        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "Will turn to brightest day.",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 23
      } ]
    }, {
      "text" : "Then let us all take courage,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "For we're not left alone;",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 20
      } ]
    }, {
