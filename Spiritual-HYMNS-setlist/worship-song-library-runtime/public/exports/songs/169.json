        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "I'll guide you to that land.\"",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
