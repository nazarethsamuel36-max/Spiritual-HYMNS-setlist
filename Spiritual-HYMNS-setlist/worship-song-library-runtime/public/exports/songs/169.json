  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "We're floating down the stream of time,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      } ]
    }, {
      "text" : "We have not long to stay;",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
