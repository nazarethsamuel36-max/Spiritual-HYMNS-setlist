      "chords" : [ {
        "chord" : "D",
        "position" : 1
      }, {
        "chord" : "A",
        "position" : 16
      } ]
    }, {
      "text" : "We're pilgrims and we're strangers here,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "We're seeking a city to come,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    }, {
      "text" : "The lifeboat soon is coming,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "To gather the Jewels home."
    } ]
