  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "The Lord's my Shepherd, I'll not want",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 24
      }, {
        "chord" : "A",
        "position" : 33
      } ]
    }, {
      "text" : "He makes me down to lie,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "In pastures green; He leadeth me",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "The quiet waters by.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "My soul He doth restore again,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 25
      } ]
    }, {
      "text" : "And me to walk doth make,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "Within the paths of righteousness,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "A",
        "position" : 29
      } ]
    }, {
      "text" : "E'en for His own name's sake.",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "Yea, though I walk in death's dark vale",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "A",
        "position" : 35
      } ]
    }, {
      "text" : "Yet will I fear none ill;",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "For Thou art with me, and Thy rod",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "And staff me comfort still.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "My table Thou hast furnished",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 9
      }, {
        "chord" : "D",
        "position" : 19
      }, {
        "chord" : "A",
        "position" : 26
      } ]
    }, {
      "text" : "In presence of my foes;",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "My head Thou dost with oil anoint",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 23
      }, {
        "chord" : "A",
        "position" : 29
      } ]
    }, {
      "text" : "And my cup overflows.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "Goodness and mercy all my life",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 19
      }, {
        "chord" : "A",
        "position" : 26
      } ]
    }, {
      "text" : "Shall surely follow me,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
