        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "A",
        "position" : 23
      } ]
    }, {
      "text" : "It shall come as the dawning of the day,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "A",
        "position" : 36
      } ]
    }, {
      "text" : "For the knowledge of the Lord;",
