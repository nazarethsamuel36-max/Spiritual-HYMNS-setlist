  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Let the Lord have His way",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "In your life every day;",
      "chords" : [ {
        "chord" : "G",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "There's no peace, there's no rest",
      "chords" : [ {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    }, {
      "text" : "Till the Lord has His way;",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : "Put your life in His hands,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      } ]
    }, {
      "text" : "Rest secure in His plans,",
      "chords" : [ {
        "chord" : "G",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "Let the Lord, let the Lord have His way",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
