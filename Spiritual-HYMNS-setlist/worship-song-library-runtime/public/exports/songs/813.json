        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "Was veiled off from human view;",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    }, {
      "text" : "But through suffering, death and sorrow,",
