    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "पवित्र आत्मा प्रेमी पवित्र आत्मा",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "आ इस दिल में घर तू बना ले,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "रह मेरे संग तू सदा।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "किचसे निकाला हमें, शुद्ध तुने किया हमें,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    }, {
      "text" : "खूनसे धो प्रभू श्वेत तू करना धन्य नाम हो तेरा।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 29
      }, {
        "chord" : "G",
        "position" : 43
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "सिनाय पर्वतपर जैसे तू उतरा प्रभु,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "वैसे इस दिल में उतरकर प्रभु पवित्र हमको बना।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 28
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "पवित्र हाथों से प्रभू हरपल हमको संभाल,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    }, {
      "text" : "आत्मा के दान तू दे प्रभु हमको रुपमें अपने तू ढाल ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 16
      }, {
        "chord" : "D",
