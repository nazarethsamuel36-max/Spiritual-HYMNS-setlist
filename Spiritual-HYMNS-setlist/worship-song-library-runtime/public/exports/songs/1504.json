  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "दिवसा सुटणार बाण,"
    }, {
      "text" : "काळोखात फिरणारी मारी (२)"
    }, {
      "text" : "ह्याची बाधा मला होणार नाही,"
    }, {
      "text" : "तुझे वाचन सत्य ढाल आहे (२)"
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "तुझी दया सनातन आहे......"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "माझ्या बाजूस सहस्त्रावधी पडले,"
    }, {
      "text" : "उजव्या हातास लक्षावधी पडले (२)"
    }, {
      "text" : "तरी ती मला भिडणार नाही,"
    }, {
      "text" : "कारण प्रभू माझा आश्रय आहे (२)"
    } ]
