{
  "id" : 853,
  "songNumber" : 241,
  "title" : "IN THESE DAYS OF TRIALS SO NEAR THE END",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "In these days of trials so near the end,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "When Christ from Glory doth now descend,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "A",
        "position" : 28
      } ]
    }, {
      "text" : "Men's hearts are failing and filled with fear,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    }, {
      "text" : "We know the end time is surely here.",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "So just be faithful, believe His word;",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 23
      }, {
        "chord" : "D",
        "position" : 33
      } ]
    }, {
      "text" : "Stay with the Message that you have heard;",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    }, {
      "text" : "List' to His prophet, his Message heed;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    }, {
      "text" : "Walk in the Light where His star doth lead.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "In every church age a star did shine.",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : "To help God's people a Truth to find;",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "A",
        "position" : 23
      } ]
    }, {
      "text" : "In this last church age a star shines bright.",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    }, {
      "text" : "So friend receive It, walk in the light.",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "His Word of promise he gave the Bride,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "From his White Charger the prophet cried.",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    }, {
      "text" : "\"Yet one more time shall I ride this trail.\"",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "THUS SAITH THE LORD can never fail.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    } ]
  } ]
}