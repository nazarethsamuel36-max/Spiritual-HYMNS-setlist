    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "God is good all the time",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "He put a song of praise in this heart of mine",
      "chords" : [ {
        "chord" : "G",
        "position" : 9
      }, {
        "chord" : "D",
        "position" : 17
      }, {
        "chord" : "A",
        "position" : 32
      } ]
    }, {
      "text" : "God is good all the time"
    }, {
      "text" : "Through the darkest night, His light will shine",
      "chords" : [ {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "A",
        "position" : 31
      } ]
    }, {
      "text" : "God is good, God is good all the time",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "If you're walking through the valley,",
      "chords" : [ {
        "chord" : "G",
        "position" : 10
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "And there are shadows all around,",
      "chords" : [ {
        "chord" : "D",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "Do not fear, He will guide you,",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "He will keep you safe and sound,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "A",
        "position" : 26
      } ]
    }, {
      "text" : "'Cause He's promised to never leave you,",
      "chords" : [ {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    }, {
      "text" : "Nor forsake you and His Word is true.",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "We were sinners - so unworthy,",
      "chords" : [ {
        "chord" : "G",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "Still for us He chose to die,",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "Filled us with His Holy Spirit,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 19
      } ]
    }, {
      "text" : "Now we can stand and testify,",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "A",
        "position" : 26
      } ]
    }, {
      "text" : "That His love is everlasting,",
      "chords" : [ {
        "chord" : "G",
        "position" : 9
      }, {
        "chord" : "A",
        "position" : 17
      } ]
    }, {
      "text" : "And His mercies - they will never end.",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "A",
        "position" : 28
      } ]
    } ]
  } ]
}