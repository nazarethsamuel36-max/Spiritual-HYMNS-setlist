{
  "id" : 795,
  "songNumber" : 183,
  "title" : "ALAS AND DID MY SAVIOUR BLEED",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "Alas! and did my Saviour bleed,",
      "chords" : [ {
        "chord" : "D",
        "position" : 1
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "And did my Sovereign die ?",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "Would He devote that sacred head",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "For such a worm as I ?",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "Chorus",
    "lines" : [ {
      "text" : "At the cross, at the cross where I first saw the light,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 35
      } ]
    }, {
      "text" : "And the burden of my heart rolled away,",
      "chords" : [ {
        "chord" : "A",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    }, {
      "text" : "It was there by faith I received my sight,",
      "chords" : [ {
        "chord" : "G",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    }, {
      "text" : "And now I am happy all the day !",
      "chords" : [ {
        "chord" : "A",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "Was it for crimes that I have done,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 23
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "He groaned upon the tree ?",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 20
      } ]
    }, {
      "text" : "Amazing pity, grace unknown,",
      "chords" : [ {
        "chord" : "D",
        "position" : 1
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "And love beyond degree !",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "Well might the sun in darkness hide,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : "And shut his glories in,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "When Christ the mighty Maker, died",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 23
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "For man, the creature's sin.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "But drops of grief can ne'er repay",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 23
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : "The debt of love I owe ;",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 19
      } ]
    }, {
      "text" : "Here, Lord, I give myself away,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "'Tis all that I can do !",
      "chords" : [ {
        "chord" : "A",
        "position" : 5
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    } ]
  } ]
}