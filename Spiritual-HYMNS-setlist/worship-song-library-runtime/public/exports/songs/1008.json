  "title" : "जिन्दगी मेरी बदल गई, जबसे मसीह को पाया है",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "जिन्दगी मेरी बदल गई, जबसे मसीह को पाया है,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 34
      } ]
    }, {
      "text" : "खिल गई है कलियाँ नई, यीशु बहार लाया है ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "A",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "जीवन है क्या, पल ही दो पल का,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    }, {
      "text" : "किसने है जाना होगा क्या कल का ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "घडियाँ सुनहरी, फिर न लौटेंगी,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "मुक्ति और जीवन वो लाया है ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "मार्ग में हमारे वह दर्शक रहेगा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "कदम डगमगाएँ हाथ वह थामेगा ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 12
      } ]
    }, {
      "text" : "भटके हुओं को राह दिखाने,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 13
      } ]
    }, {
      "text" : "इस धरती पर वह आया है ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 11
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "जीवन की रोटी और अमृत जल को,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "कैसी भरपूरी से देता वह हमको,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "लहू बहाकर पाप हमारा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 10
      } ]
    }, {
      "text" : "प्यारे प्रभु ने उठाया है ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    } ]
  } ]
}