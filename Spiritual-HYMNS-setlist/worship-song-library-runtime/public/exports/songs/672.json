{
  "id" : 672,
  "songNumber" : 365,
  "title" : "BRING A PSALM TO THE LORD",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Bring a Psalm to the Lord",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 14
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "From the Spirit and from His word,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "A",
        "position" : 25
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    }, {
      "text" : "Lift your voice and rejoice",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : "For our God is a mighty King,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    }, {
      "text" : "So come and clap your hands,",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : "Raise a shout,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 8
      } ]
    }, {
      "text" : "As we stand before the Lord,",
      "chords" : [ {
        "chord" : "G",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 14
      }, {
        "chord" : "A",
        "position" : 23
      } ]
    }, {
      "text" : "For the Lord is He who has the power to free,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 23
      }, {
        "chord" : "A",
        "position" : 31
      }, {
        "chord" : "D",
        "position" : 40
      } ]
    }, {
      "text" : "Who by His mighty arm,",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "A",
        "position" : 18
      } ]
    }, {
      "text" : "Gives strength and victory,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "So we hail the King, then let His praises ring,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 26
      }, {
        "chord" : "A",
        "position" : 34
      }, {
        "chord" : "D",
        "position" : 42
      } ]
    }, {
      "text" : "And bring a psalm of joy before the Lord.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "A",
        "position" : 21
      }, {
        "chord" : "G",
        "position" : 27
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    } ]
  } ]
}