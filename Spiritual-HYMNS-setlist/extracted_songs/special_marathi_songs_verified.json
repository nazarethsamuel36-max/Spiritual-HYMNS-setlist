[
  {
    "number": 1501,
    "title": "माझा येशु मला प्रिय फार",
    "language": "marathi",
    "book": "special_marathi",
    "originalKey": "G",
    "sections": [
      {
        "type": "chorus",
        "label": "CHORUS",
        "lines": [
          "माझा येशु मला प्रिय फार",
          "ह्या जीवनात तोच आधार",
          "आपत्तीत विपत्तीत ह्या जीवन यात्रेत",
          "तो कधी ना मला सोडणार"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 2",
        "lines": [
          "हा जीवन प्रवास कठीण,",
          "येते अनेक प्रतिकूल क्षण",
          "दिवसा मेघ स्तंभ, रात्री अग्नी स्तंभ,",
          "माझे वाटाडे प्रति दिन"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 3",
        "lines": [
          "तो आधी व अंत आहे,",
          "हृदयी आनंदाचा झरणा वाहे",
          "दुःख येता क्षणी, अश्रू पुसतो क्षणीच,",
          "माझा प्रतिदिन भार वाहे"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 4",
        "lines": [
          "माझ्या येशु ची अपरंपार प्रीती,",
          "मला नाही कशाची भीती",
          "क्लेश संकट मरण, नग्नता उपोषण,",
          "ख्रिस्ता संगे विजय प्राप्ती"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 5",
        "lines": [
          "माझा येशु मला प्रिय फार",
          "ह्या जीवनात तोच आधार",
          "आपत्तीत विपत्तीत ह्या जीवन यात्रेत",
          "तो कधी न मला सोडणार"
        ]
      }
    ]
  },
  {
    "number": 1502,
    "title": "तुझंसा कोणी नाही",
    "language": "marathi",
    "book": "special_marathi",
    "originalKey": "E",
    "sections": [
      {
        "type": "chorus",
        "label": "CHORUS",
        "lines": [
          "तुझंसा कोणी नाही, तुझंसा कुठे नाही",
          "विश्वास हा मणी, तुझंसा कोणी नाही"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 1",
        "lines": [
          "ख्रिस्त येसू हो महिमा तुझी",
          "गाते आकाश, गाते ही धरती"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 2",
        "lines": [
          "अंधकारत प्रकाश तू आहे",
          "तूच मुकाम, तू प्रवास रे",
          "तू जिथे, ना कहि कामे अहे",
          "तुझं नव हे जीवन रे"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 3",
        "lines": [
          "हालेलुयाह, हालेलुयाह..."
        ]
      }
    ]
  },
  {
    "number": 1503,
    "title": "तारक तो सामर्थ्य तो",
    "language": "marathi",
    "book": "special_marathi",
    "originalKey": "Gm",
    "sections": [
      {
        "type": "verse",
        "label": "VERSE 1",
        "lines": [
          "हा दिवस प्रभूचा आहे",
          "उल्हास व आनंद करू...(२)",
          "किती थोर तो देव",
          "सर्वस्व आपणांस दिले...(२)"
        ]
      },
      {
        "type": "chorus",
        "label": "CHORUS",
        "lines": [
          "तारक तो सामर्थ्य तो",
          "येशू देव युगानयुग आहे...(२)",
          "हा.. हा.. हा.. हा.. हाल्लेलुया",
          "हो.. हो.. हो.. हो.. होसान्ना...(२)",
          "हाल्लेलुया... हाल्लेलुया...",
          "हाल्लेलुया...(२)"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 2",
        "lines": [
          "चला हो आता त्याकडे",
          "महिमा स्तुती वर्णू...(२)",
          "स्वर्गाच्या देवाला",
          "स्तुतीचे गीत गाऊ...(२)"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 3",
        "lines": [
          "त्याचा अनुभव घ्या",
          "किती तो चांगला आहे...(२)",
          "सैतानी बंधनातूनी",
          "आपणांस सोडवितो...(२)"
        ]
      }
    ]
  },
  {
    "number": 1504,
    "title": "तुझी दया सनातन आहे",
    "language": "marathi",
    "book": "special_marathi",
    "originalKey": "G",
    "sections": [
      {
        "type": "verse",
        "label": "VERSE 1",
        "lines": [
          "तुझी दया सनातन आहे,",
          "तुझी करून सदाची आहे (२)",
          "तुझ्या पंखा खाली आश्रय मला,",
          "तुझ्या नावा मधे जीवन मला (२)"
        ]
      },
      {
        "type": "chorus",
        "label": "CHORUS",
        "lines": [
          "तुझी दया सनातन आहे......"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 2",
        "lines": [
          "दिवसा सुटणार बाण,",
          "काळोखात फिरणारी मारी (२)",
          "ह्याची बाधा मला होणार नाही,",
          "तुझे वाचन सत्य ढाल आहे (२)"
        ]
      },
      {
        "type": "chorus",
        "label": "CHORUS",
        "lines": [
          "तुझी दया सनातन आहे......"
        ]
      },
      {
        "type": "verse",
        "label": "VERSE 3",
        "lines": [
          "माझ्या बाजूस सहस्त्रावधी पडले,",
          "उजव्या हातास लक्षावधी पडले (२)",
          "तरी ती मला भिडणार नाही,",
          "कारण प्रभू माझा आश्रय आहे (२)"
        ]
      },
      {
        "type": "chorus",
        "label": "CHORUS",
        "lines": [
          "तुझी दया सनातन आहे......"
        ]
      }
    ]
  }
]
