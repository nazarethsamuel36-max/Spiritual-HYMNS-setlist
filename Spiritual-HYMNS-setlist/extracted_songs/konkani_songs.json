[
  {
    "number": 378,
    "title": "JEZU TUJIM UTRAM",
    "language": "konkani",
    "book": "konkani",
    "sections": [
      {
        "type": "verse",
        "label": "Verse 1",
        "lines": [
          "Jezu, tujim utram kallzacho sontos,",
          "Jezu, tujim utram dolleancho uzvadd,",
          "Jezu, tujim utram jinnecho visvas!"
        ]
      },
      {
        "type": "verse",
        "label": "Verse 2",
        "lines": [
          "Jezu, tujim utram tanel'leank udok,",
          "Jezu, tujim utram bhukel'leank jevonn,",
          "Jezu, tujim utram meloleank jivit!"
        ]
      },
      {
        "type": "verse",
        "label": "Verse 3",
        "lines": [
          "Jezu, tujim utram roddteleank buzvonn,",
          "Jezu, tujim utram opradeank mafi,",
          "Jezu, tujim utram gulamank suttka!"
        ]
      }
    ]
  },
  {
    "number": 379,
    "title": "ZANNAIM TUM (Know Ye Not)",
    "language": "konkani",
    "book": "konkani",
    "sections": [
      {
        "type": "verse",
        "label": "Verse 1",
        "lines": [
          "Zannaim Tum, Zannaim Tum",
          "Devachem mondir",
          "Dev Spiritachem Mondir Tum."
        ]
      },
      {
        "type": "chorus",
        "label": "Chorus",
        "lines": [
          "Mellun Mog, Mellun Mog,",
          "Mellun Jivit (3)",
          "Dev Spiritachem Mondir Tum"
        ]
      },
      {
        "type": "verse",
        "label": "Verse 2",
        "lines": [
          "Hallelu, Hallelu, Hallelujah (3)",
          "Dev Spiritachem Mondir Tum."
        ]
      }
    ]
  },
  {
    "number": 380,
    "title": "ARGAM TUKA SOMIA",
    "language": "konkani",
    "book": "konkani",
    "sections": [
      {
        "type": "verse",
        "label": "Verse 1",
        "lines": [
          "Argam Tuka, Somia,",
          "Argam Tuka, Dhonia,",
          "Argam Tuka, argam Tuka",
          "Atam anim sasnnak."
        ]
      },
      {
        "type": "verse",
        "label": "Verse 2",
        "lines": [
          "Tuvem mhaka rochloi Tuzo mog korcheak,",
          "Tuvem mhaka posloi Tuzi chakri korcheak,",
          "Tuvem mhaka vinchloi sasnak sukak pavcheak,",
          "Tori mhaka favo nhoi, Somia mhaka favo nhoi."
        ]
      },
      {
        "type": "verse",
        "label": "Verse 3",
        "lines": [
          "Nimannea tea jevnnar ho sacrifice goddloi,",
          "Mhojem taronn korcheak Jezuk hettoun diloi,",
          "Sasnachea mornantlo mhaka tuvem rakhloi,",
          "Tori maka favo nhoi, Somia maka favo nhoi."
        ]
      }
    ]
  },
  {
    "number": 381,
    "title": "SORVESPORA DEVA",
    "language": "konkani",
    "book": "konkani",
    "sections": [
      {
        "type": "verse",
        "label": "Verse 1",
        "lines": [
          "Sorvespora sorg ani Sounvsar",
          "Tuvem rochlai tujeach hatan",
          "Kainch kotin nhoi Tuka (2)",
          "Dhonia tum Sorvpodvedar",
          "Tunch amcho dhir ani adar",
          "Kainch kotin nhoi (2)",
          "Kainch kotin nhoi Tuka"
        ]
      }
    ]
  },
  {
    "number": 382,
    "title": "TO MOJEM SOGLLEM DAIZ (He Is My Everything)",
    "language": "konkani",
    "book": "konkani",
    "sections": [
      {
        "type": "verse",
        "label": "Verse 1",
        "lines": [
          "Toch mojem sogllem Daiz,",
          "Toch mojem dhyan",
          "Toch, mojem sogllem Daiz",
          "Vodd ani lhan",
          "Moje passun koxtt sosun",
          "Dilo Tannem prann",
          "Sogleanch novem korun, Zalo mojem khann."
        ]
      },
      {
        "type": "verse",
        "label": "Verse 2",
        "lines": [
          "Khoddpantlea mhonva bhaxen",
          "Ghodd ruchik mhonva bhaxen",
          "To unch khoddpantlea mhonva bhaxen",
          "Chakun polleiat, Somi kai boro",
          "Khodpantulem mhon'unch khoro"
        ]
      },
      {
        "type": "verse",
        "label": "Verse 3",
        "lines": [
          "Lokan amkam vincharlear",
          "Lokan mhonnlear",
          "Konn vortouta Jezu, tumchea kallzak?",
          "Moje passot melo To, Maka novo korcheak",
          "Aikat sangtam tumkam, To ixtt mozo."
        ]
      }
    ]
  },
  {
    "number": 383,
    "title": "ASSONDHI MOG",
    "language": "konkani",
    "book": "konkani",
    "sections": [
      {
        "type": "verse",
        "label": "Verse 1",
        "lines": [
          "Assondhi mog amchea modhem",
          "Assondhi mog amchea kallzanim",
          "Vistarunk dhi mog amchea dhesant",
          "Magtam somia dhi amkam kurpa",
          "Dhi amkam bori somzoni",
          "Zanna zaumcheak mog bhav-boinancho",
          "Assondhi mog amchea modhem",
          "Assondhi mog."
        ]
      }
    ]
  },
  {
    "number": 384,
    "title": "TUKA AMIM POLEUNK NAM",
    "language": "konkani",
    "book": "konkani",
    "sections": [
      {
        "type": "verse",
        "label": "Verse 1",
        "lines": [
          "Tuka amim polleunk nam,",
          "Punn tujer amcho bhavart",
          "Jezu amchea Taroka (4)"
        ]
      },
      {
        "type": "verse",
        "label": "Verse 2",
        "lines": [
          "Jezu sorv utram tujim",
          "Sasnachea Jivitachim,",
          "Konnazim vochum amim",
          "Jezu amchea Taroka (4)"
        ]
      },
      {
        "type": "verse",
        "label": "Verse 3",
        "lines": [
          "Tuka amim poleunk nam,",
          "Punn Tujer visvas thevtaum",
          "Jezu amchea Taroka (4)"
        ]
      },
      {
        "type": "verse",
        "label": "Verse 4",
        "lines": [
          "Jezu tum eklo amkam",
          "Bhasaitai sasnik jivit",
          "Bhasaunnim pett'ta visvas",
          "Jezu amchea Taroka (4)"
        ]
      },
      {
        "type": "verse",
        "label": "Verse 5",
        "lines": [
          "Tuka amim polleunk nam",
          "Tori mog tuzo kortaum",
          "Jezu amchea Taroka (4)"
        ]
      },
      {
        "type": "verse",
        "label": "Verse 6",
        "lines": [
          "Jezu tum chodd chodd boro,",
          "Soglo mog tuka favo,",
          "Amchem sukh tujea mogan",
          "Jezu amchea Taroka (4)"
        ]
      }
    ]
  },
  {
    "number": 385,
    "title": "VOI DEV BORO (YES GOD IS GOOD)",
    "language": "konkani",
    "book": "konkani",
    "sections": [
      {
        "type": "verse",
        "label": "Verse 1",
        "lines": [
          "Voi Dev boro (3)",
          "Maka Bhou boro",
          "Sorvesporak Jai Jai",
          "Sasnak, Sasnak Jai Jai",
          "Soglea kallzan mhonnuia Jai Jai",
          "Sorvesporak sodamkal Jai, Jai, Jai"
        ]
      }
    ]
  }
]
