```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js
*.jsx
*.ts
*.tsx

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp

# IDE specific
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage reports
coverage/
htmlcov/
.coverage

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# OS generated files
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```