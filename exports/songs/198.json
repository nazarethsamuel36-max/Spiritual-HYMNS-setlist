        "position" : 3
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 35
      } ]
    }, {
      "text" : "The \"faroff country\" wand'rings all are done,",
      "chords" : [ {
