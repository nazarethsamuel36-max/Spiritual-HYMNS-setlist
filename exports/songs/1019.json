  "sections" : [ {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "तेरे पाप धुल सकेंगे आज ही मसीह के द्वारा,",
      "chords" : [ {
        "chord" : "E",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 20
      }, {
        "chord" : "B",
        "position" : 34
      } ]
    }, {
      "text" : "सिर्फ एक नजर उठा के देख ले लहू की धारा ।",
      "chords" : [ {
        "chord" : "E",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 20
      }, {
        "chord" : "B",
        "position" : 27
      }, {
        "chord" : "E",
        "position" : 34
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "तेरे कोशिशों के बदले क्या बता तुझे मिला है?",
      "chords" : [ {
        "chord" : "E",
        "position" : 0
