      }, {
        "chord" : "Dm",
        "position" : 29
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "गुनाहों से जग को छुड़ाया,अपना लहू बहाकर ।",
