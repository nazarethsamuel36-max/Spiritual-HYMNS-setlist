        "chord" : "Dm",
        "position" : 28
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "कोई कदर न जानी फिर भी किसी ने उसकी ।",
