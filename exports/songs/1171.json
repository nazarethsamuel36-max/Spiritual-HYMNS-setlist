{
  "id" : 1171,
  "songNumber" : 193,
  "title" : "भॊऒमि कि उत्पत्ति सॆ पॆह्लॆ प्रभु",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "भूमि कि उत्पत्ति से पहले प्रभु,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "मेरे नाम को लिख लिया।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "ज्ञान से अपने यीशु ने, मुझको पहचान लिया।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "A",
        "position" : 23
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "गर्भ में मुझको बोया और प्यार से उगने दिया,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 23
      }, {
        "chord" : "D",
        "position" : 37
      } ]
    }, {
      "text" : "मेरे जन्म से लेकर अब तक मेरी रखवाली की,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 36
      } ]
    }, {
      "text" : "मैं पापों में मर गया था, मुझे यीशु ने जिंदा किया।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "A",
        "position" : 30
      }, {
        "chord" : "D",
        "position" : 44
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "जीवित वचन सुनाकर पछताने को समय दिया,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : "मैं जब मन फिराया तो मुझको स्वीकार किया,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "A",
        "position" : 34
      } ]
    }, {
      "text" : "यीशु चरणों में स्थान दिया।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "जब से तौबा किया मेरे जीवन को बदल दिया,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 33
      } ]
    }, {
      "text" : "अपने ही नाम से मुझको पानी में जन्म दिया,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "A",
        "position" : 35
      } ]
    }, {
      "text" : "नया जीवन मुझको देकर मुझे अपना ही पुत्र कहा।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "A",
        "position" : 25
      }, {
        "chord" : "D",
        "position" : 39
      } ]
    } ]
  } ]
}