        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "हम पर रहे तेरी करुणा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "तन-मन-धन हमारा तेरा है,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      } ]
    }, {
      "text" : "इन्हे शैतान को छूने न देना ।",
