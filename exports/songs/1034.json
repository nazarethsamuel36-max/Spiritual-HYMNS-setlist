      }, {
        "chord" : "D",
        "position" : 25
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "सारी सृष्टि को तेरा सहारा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "सारी संकट से हमको बचाना,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "तेरे हाथो मे जीवन हमारा है,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      } ]
    }, {
      "text" : "अपनी राहों पर हमको चलाना ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "हम हैं तेरे हाथों की रचना,",
