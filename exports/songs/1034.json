  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "सारी सृष्टी के मालिक तुम्ही हो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "सारी सृष्टी के रक्षक तुम्ही हो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "करते हैं तुझको सादर प्रणाम,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      } ]
    }, {
      "text" : "गाते हैं तेरे ही गुणगान ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "हा-हा-हाल्लेलुयाह...(7) आमीन ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 6
      }, {
        "chord" : "Em",
        "position" : 17
      }, {
        "chord" : "Am",
