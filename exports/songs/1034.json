        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
