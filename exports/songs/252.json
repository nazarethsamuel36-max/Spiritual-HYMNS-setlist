        "chord" : "D",
        "position" : 39
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "Oh, Master, grant that I may never seek,",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    }, {
      "text" : "So much to be consoled as to console,",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    }, {
      "text" : "To be understood as to understand,",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "To be loved, as to love with all my soul.",
      "chords" : [ {
        "chord" : "E",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 13
      }, {
