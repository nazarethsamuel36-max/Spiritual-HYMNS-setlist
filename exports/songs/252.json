        "chord" : "G",
        "position" : 25
      }, {
        "chord" : "A",
        "position" : 43
      } ]
    }, {
      "text" : "Where there is darkness, only light",
      "chords" : [ {
        "chord" : "G",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "And where there's sadness, ever joy.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 18
      }, {
        "chord" : "G",
        "position" : 27
