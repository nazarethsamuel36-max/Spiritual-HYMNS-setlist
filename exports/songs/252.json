  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Make me a channel of your peace,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    }, {
      "text" : "Where there is hatred let me bring your love,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "A",
        "position" : 40
      } ]
    }, {
      "text" : "Where there is injury your pardon, Lord,",
      "chords" : [ {
        "chord" : "G",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "And where there's doubt, true faith in you.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 18
      }, {
        "chord" : "G",
