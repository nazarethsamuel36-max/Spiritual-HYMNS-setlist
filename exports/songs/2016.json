  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "उस क्रूस की क्या बात है जिसने है हमको बचाया"
    }, {
      "text" : "यीशु मसीह ने तेरे लिए, मेरे लिए लहू बहाया...२"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "जब मैं गुनाहों में डुबा हुआ था"
    }, {
      "text" : "उस क्रूसपर मेरा नाम लिखा था...२"
    }, {
      "text" : "यीशूने अपना खून बहाकर"
    }, {
      "text" : "उस नाम को है मिटाया"
    }, {
      "text" : "यीशू मसीहने तेरे लिए"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "जब वो चढाया था उस क्रूसपर"
    }, {
      "text" : "मसीह ने कहा ऐ पिता माफ कर...२"
    }, {
      "text" : "माफ कर दे उन लोगों को"
    }, {
      "text" : "जिसने मुझे ठुकराया"
    }, {
      "text" : "यीशु मसीहने तेरे लिए.."
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "अब है गुनाहों से क्या वास्ता"
    }, {
      "text" : "मसीह संग रहूँ मैं, रहमें सदा हा...२"
    }, {
      "text" : "पिता के ही चरणों में गाता रहूँ मैं"
    }, {
      "text" : "अब ये गीत दुबारा"
    }, {
      "text" : "यीशू मसीहने तेरे लिए..."
    } ]
  } ]
}