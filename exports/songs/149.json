{
  "id" : 761,
  "songNumber" : 149,
  "title" : "THERE'S A LAND THAT IS FAIRER THAN DAY",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "There's a land that is fairer than day,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 35
      } ]
    }, {
      "text" : "And by faith we can see it afar;",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "For the Father waits over the way,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "To prepare us a dwelling place there.",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 31
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "In the sweet by and by,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "We shall meet on that beautiful shore;",
      "chords" : [ {
        "chord" : "G",
        "position" : 9
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    }, {
      "text" : "In the sweet by and by,"
    }, {
      "text" : "We shall meet on that beautiful shore.",
      "chords" : [ {
        "chord" : "G",
        "position" : 9
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "We shall sing on that beautiful shore,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "A",
        "position" : 32
      } ]
    }, {
      "text" : "The melodious songs of the blest,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "And our spirits shall sorrow no more,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 32
      } ]
    }, {
      "text" : "Not a sigh for the blessing of rest.",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 31
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "To our bountiful Father above,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 25
      } ]
    }, {
      "text" : "We will offer our tribute of praise,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    }, {
      "text" : "For the glorious gift of His love,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 29
      } ]
    }, {
      "text" : "And the blessings that hallow our days.",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    } ]
  } ]
}