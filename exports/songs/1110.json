  "hashtags" : [ ],
  "sections" : [ {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "यीशु का लहू सारे पापों से शुद्ध करता हमें",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 26
      } ]
    }, {
      "text" : "उद्धार देता, शांती देता, अनंत जीवन भी देता ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 40
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "पवित्र स्थान में जायेंगे हम,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 25
      } ]
    }, {
      "text" : "उसके लहू के ही द्वारा",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "द्वार हमारा यीशु है प्यारा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 20
      } ]
    }, {
      "text" : "वही है भोर का तारा ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "ना हम खुदके, ना दुनिया के,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 23
      } ]
    }, {
      "text" : "हम तो है यीशु मसिह के",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "हम विश्वासी इस जहा में,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 19
      } ]
    }, {
      "text" : "गवाह है उसके लहू से ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "ऐसा कभी ना सोचो मन में,",
