{
  "id" : 746,
  "songNumber" : 134,
  "title" : "MY FAITH LOOKS UP TO THEE",
  "language" : "english",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "My faith looks up to Thee,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "Thou Lamb of Calvary,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "Saviour divine;",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      } ]
    }, {
      "text" : "Now hear me while I pray,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 20
      } ]
    }, {
      "text" : "Take all my sin away,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    }, {
      "text" : "O let me from this day",
      "chords" : [ {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "Be wholly Thine !",
      "chords" : [ {
        "chord" : "A",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 10
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "May Thy rich grace impart",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "Strength to my fainting heart,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "My zeal inspire;",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      } ]
    }, {
      "text" : "As Thou hast died for me,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : "O may my love to Thee,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    }, {
      "text" : "Pure, warm, and changeless be,",
      "chords" : [ {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "A living fire !",
      "chords" : [ {
        "chord" : "A",
        "position" : 2
      }, {
        "chord" : "D",
        "position" : 9
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "While life's dark maze I tread,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 25
      } ]
    }, {
      "text" : "And griefs around me spread,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "Be Thou my Guide;",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      } ]
    }, {
      "text" : "Bid darkness turn to day,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "Wipe sorrow's tears away,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "Nor let me ever stray",
      "chords" : [ {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "From Thee aside.",
      "chords" : [ {
        "chord" : "A",
        "position" : 5
      }, {
        "chord" : "D",
        "position" : 11
      } ]
    } ]
  } ]
}