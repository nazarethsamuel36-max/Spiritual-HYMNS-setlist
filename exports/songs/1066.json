{
  "id" : 1066,
  "songNumber" : 88,
  "title" : "प्रभु तॆर हुन् तॆरॆ वछन् सॆ",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "प्रभु तेरा हूँ तेरे वचन से,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "तेरा प्रेम पहचानता हूँ ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "मेरी कामना है कि विश्वास से मैं,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 17
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "जा के तेरे पास रहूँ ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "रख तू मुझको, मुझको हे मसीह,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "अपने क्रुस के सोते पास, रख तू मुझको,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "मुझको, मुझको हे मसीह ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    }, {
      "text" : "अपने घायल पांजर पास ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "आत्मा भेज, कर शुद्ध, सेवा योग्य बना,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 21
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    }, {
      "text" : "मुझको सेवा में लगा, मेरा मन कर स्थिर,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "मेरी इच्छा को अपनी इच्छा में मिला ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 31
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "अपनी प्रार्थना में जैसे मित्र से,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 19
      }, {
        "chord" : "G",
        "position" : 30
      } ]
    }, {
      "text" : "वैसे तुझ से बात करूँ,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    }, {
      "text" : "एक घडी भी जो तेरा साथ मिले,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "तो महा-आनंदित हूँ ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "सबसे गहरा प्रेम मैं न जानूंगा",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "जब तक स्वर्ग न पहुंचूंगा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "सबसे श्रेष्ठ आनंद तब मिलेगा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 18
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "जब तुझ को साक्षात देखूंगा ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
