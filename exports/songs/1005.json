  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "आदि और अंत तू ही है,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 11
      } ]
    }, {
      "text" : "अल्फा और ओमेगा तू ही है ।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "दूतों की स्तुति तू ही है,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 16
      } ]
    }, {
      "text" : "बुद्धि और ज्ञान तू ही है ।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "यीशु तू महान है, यीशु तू सच्चा है ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "C",
        "position" : 26
      } ]
    }, {
      "text" : "यीशु तू जिन्दा है, यीशु तू धन्य है ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "C",
        "position" : 28
      } ]
    }, {
      "text" : "दूतों की स्तुति तू ही है,"
    }, {
      "text" : "बुद्धि और ज्ञान तू ही है ।"
    }, {
      "text" : "राजाओं का राजा तू ही है,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "प्रभुओं का प्रभु तू ही है ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "जीवन मेरा पापों से भरा,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 10
      } ]
    }, {
      "text" : "जग अंधेरा और अशुद्ध सारा ।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    }, {
      "text" : "मेरे पापों से बचाने को,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 15
      } ]
    }, {
      "text" : "मेरे लिये जीवन दिया है ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "सारे गुनाहगारों के लिये,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 10
      } ]
    }, {
      "text" : "अपना खून बहाया उसने ।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 10
      } ]
    }, {
      "text" : "खाई कोड़ों की मार भी,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 14
      } ]
    }, {
      "text" : "दी सलीब पर उसने अपनी जान ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 18
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "न्याय करने आने वाला है,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "न्याय के साथ राज्य करने को ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 13
      } ]
    }, {
      "text" : "धर्मियों को लेकर न्याय से,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 17
      } ]
    }, {
      "text" : "सिंहासन पर राज्य करेगा ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 17
      } ]
    } ]
  } ]
