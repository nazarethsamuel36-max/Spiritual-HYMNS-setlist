  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "God is good to me,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Oh what love I see,"
    }, {
      "text" : "Jesus as a lamb was slain,",
      "chords" : [ {
        "chord" : "A",
        "position" : 20
      } ]
    }, {
      "text" : "He delivered me, cleansed and set me free,",
      "chords" : [ {
        "chord" : "A",
        "position" : 5
      } ]
    }, {
      "text" : "Lord of all, He rose again.",
      "chords" : [ {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "Now I live, yet not I,"
    }, {
      "text" : "Jesus is alive in me,",
      "chords" : [ {
        "chord" : "D7",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "Sending the Spirit's flame",
      "chords" : [ {
        "chord" : "D",
        "position" : 12
      } ]
    }, {
      "text" : "Into my heart again,",
      "chords" : [ {
        "chord" : "A",
        "position" : 8
      } ]
    }, {
      "text" : "God has shown His love for me.",
      "chords" : [ {
        "chord" : "D",
        "position" : 27
      } ]
    } ]
  } ]
}