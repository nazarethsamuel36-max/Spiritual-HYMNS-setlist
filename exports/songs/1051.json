  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "हो शुक्रिया खुदा का जिसने जीवन हमें दिया",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
