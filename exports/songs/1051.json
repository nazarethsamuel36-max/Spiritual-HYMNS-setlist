        "chord" : "C",
        "position" : 26
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    }, {
      "text" : "तारीफ मसीह की हम करें ये हक हमें दिया ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 25
      }, {
        "chord" : "G",
        "position" : 35
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "हर चीज उसी से पायी है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      } ]
    }, {
      "text" : "मसीह की रहम से आज,",
