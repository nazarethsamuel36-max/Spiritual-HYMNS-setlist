        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 30
      } ]
    }, {
      "text" : "यीशु ही जो है प्यारा मुंजी। (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "उसने ही हम सबको बनाया",
