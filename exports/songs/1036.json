        "position" : 11
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 37
      } ]
    }, {
      "text" : "कुप्पियों में तेल रखने की, जाँच है ईमान लाने की",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
