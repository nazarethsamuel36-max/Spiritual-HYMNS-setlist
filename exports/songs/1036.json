        "position" : 37
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "देर हुई है आने में, खाली हो न तेल मशालों में",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
