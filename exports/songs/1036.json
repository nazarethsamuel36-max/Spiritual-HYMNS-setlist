        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 27
      }, {
        "chord" : "G",
        "position" : 42
      } ]
    }, {
      "text" : "बिछड न जा, रुक मत जा, वक्त है अब तैयार हो जा ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 39
      }, {
        "chord" : "G",
        "position" : 42
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "झूठे नबी और झूठे मसीह, कहते हैं तेल जरूरी नहीं",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 39
      } ]
    }, {
      "text" : "बातें मीठीसी करते हैं, मौत की ओर ले जाते हैं",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    }, {
      "text" : "जागते रहो, प्रार्थना करो इन की बातों से दूर रहो ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
