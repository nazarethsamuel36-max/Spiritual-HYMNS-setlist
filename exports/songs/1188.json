  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "मन तो प्रभु का मंदिर है, तन अपना दान करो",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 25
      } ]
    }, {
      "text" : "अपने प्रभु की सेवा में, सब अपना दान करो।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 24
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "है याद तुम्हें, जन्मे थे तुम पाप के सागर में ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 25
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    }, {
      "text" : "यीशु तुम्हे है लेने आया पाप के सागर से ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 24
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    }, {
      "text" : "उस प्यारे प्रभु के नाम के लिए, कुछ अपना दान करो।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 31
      }, {
        "chord" : "G",
        "position" : 44
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "तुम तो भटकते थे, दुनिया की अनजाने राहों में",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 17
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    }, {
      "text" : "यीशु बचाकर लाया तुमको प्यार से बाहो में",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    }, {
      "text" : "जो भी मिला है प्रभु से तुम औरों को दानं करो ।",
