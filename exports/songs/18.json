  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "दिव्य तेजे प्रकाशीत स्थळ,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "दिसे विश्वासनयने वर,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    }, {
      "text" : "तेथे आम्हांसी वस्ती अढळ",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "प्रभु देईल तो प्रियकर",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "अहा त्या सुस्थळी, पार नाही हो विश्रामा",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    }, {
      "text" : "तेथेही सुदिनी भेट होई प्रियांची आम्हां",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 32
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "तारिलेल्यांची ती गायनें,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "तेव्हां गाऊ मंजूळ स्वरे",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "नाही कोणाचे तें रडणे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "दु:ख पिडा हें गेलें सारें",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "प्रभु ख्रिस्त अत्यंत प्रेमळ,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "सर्व सत्सुख जो पुरवी,",
