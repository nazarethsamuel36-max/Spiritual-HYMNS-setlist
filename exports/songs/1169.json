  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "बढते जायेंगे आगे आगे पीछे ना मुड़कर देखेंगे",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 17
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    }, {
      "text" : "यीशु रहेगा साथ, हम ना किसीसे डरेंगे।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 35
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "चाहे हो अंधेरा चाहे हो तूफान,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      } ]
    }, {
      "text" : "हिम्मत से आगे हम बढेंगे (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "लेंगे सहारा यीशु का मंजील पर पहुँचेंगे।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "कांटो के पथपर हम चलेंगे",
