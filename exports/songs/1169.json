        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 18
      } ]
    }, {
      "text" : "कोई भी बर्दी ना होगी हमको (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "पास रखे वो हमको ऐसा जतन करेंगे।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "D",
