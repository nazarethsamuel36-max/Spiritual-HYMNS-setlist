        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "A",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "My life is no longer mine,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "I'm a prisoner of love divine",
