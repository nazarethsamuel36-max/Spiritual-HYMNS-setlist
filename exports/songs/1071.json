{
  "id" : 1071,
  "songNumber" : 93,
  "title" : "SADA MEIN STUTI KARUNGA",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "सदा मैं स्तुति करुँगा, सदा मैं सेवा करूंगा",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 23
      } ]
    }, {
      "text" : "मुझे बचाया यीशु ने, सदा मैं स्तुति करुँगा ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "मुझे बचाने आया, जब मैं गुन्हाओं में था (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      } ]
    }, {
      "text" : "स्वर्ग को छोडकर, जगत में आया, मुझे बचाने को ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "जब मैं निराशा में था, तूने मुझे आशा दी (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 22
      } ]
    }, {
      "text" : "जगत में आया, जीवन को दिया, मुझे बचाने को ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "प्रेमी प्रभु यीशु, तूने बचाया मुझे (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 19
      } ]
    }, {
      "text" : "देता हूँ अपना संपूर्ण जीवन, संपूर्ण आनंद से ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "अनंत परमेश्वर, सच्चाई जीवन तू है (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      } ]
    }, {
      "text" : "स्तुति प्रशंसा करता रहूँगा, संपूर्ण जीवन भर",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    } ]
  } ]
}