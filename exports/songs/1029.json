        "position" : 24
      }, {
        "chord" : "E",
        "position" : 33
      } ]
    }, {
      "text" : "क्यों मैं न गाऊँगा गुण उसी के, मुझे बचा लिया ।",
      "chords" : [ {
        "chord" : "E",
