{
  "id" : 1112,
  "songNumber" : 134,
  "title" : "सॆनॊन् क यॆहॊव हमरॆ सन्ग् सन्ग् है",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "सेनाओ का यहोवा हमारे संग संग है",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 21
      } ]
    }, {
      "text" : "याकुब का परमेश्वर हमारा ऊँचा गढ है ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "जिसने आकाश बनाया, जिसने पृथ्वी बनाई",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 24
      } ]
    }, {
      "text" : "वो सर्व शक्तिमान प्रभु है, वो यहोवा हमारे संग संग है।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 42
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "समुंदर को जिसने दुभागा, जंगल से मार्ग निकाला,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 24
      } ]
    }, {
      "text" : "जो वायदे को करता है पूरा, वो यहोवा हमारे संग संग है।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "लाजर को जिसने जिलाया, जक्कय को जिसने बचाया",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 22
      } ]
    }, {
      "text" : "जिसके लिए है सब कुछ संभव, वो यहोवा हमारे",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "संग संग है।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 8
      } ]
    } ]
  } ]
}