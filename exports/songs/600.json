        "chord" : "C",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    }, {
      "text" : "तरि विश्वासें तूजजवली, मज नित्य राहू दे.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 28
      }, {
        "chord" : "G",
        "position" : 37
      } ]
    }, {
      "text" : "मज जोडी, प्रभु तुजशी, तव क्रूसा दावोनी,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "मज घेई तव कुशिसी, प्रभु, घेई ओढोनी.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 25
      }, {
        "chord" : "G",
        "position" : 32
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "तव सेवेला क्षम व्हावेसे करि, ख्रिस्ता कृपेने,",
