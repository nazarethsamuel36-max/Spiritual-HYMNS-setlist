  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "आओ हम यहोवा का धन्यवाद करें,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "अपने सारे हृदय से वंदना करें,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "परम पवित्र स्थान में स्तुति करें और ललकारे ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 40
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "जिसने बनाया हमें वो हमारा आधार",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "जिसने दिया हमको साथ वो है हमारा उद्धार",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "उसकी हो जय जय हो आराधना,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "वो है प्रभुओं का प्रभु ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "अपनी पूरी तन-मन से हम उसकी महिमा करें,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "वो है शिफा और नजात उसकी प्रशंसा करें,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "वो है जग का दाता और तारणहार,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "उसकी हो जय जय सदा ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    } ]
  } ]
