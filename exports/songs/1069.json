        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "यीशु तू ताजी अब बरखा दे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "वायदे को पूरा कर अब ।",
