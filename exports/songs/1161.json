{
  "id" : 1161,
  "songNumber" : 183,
  "title" : "तन्, मन् और् धन् उसॆ दॊ",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "तन, मन और धन उसे दो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 17
      } ]
    }, {
      "text" : "अपने यीशु को सब कुछ दो;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "क्यों कि उसी के द्वारा उद्धार पाना है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 28
      } ]
    }, {
      "text" : "जीती आत्मा का दान उसे दो।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "गर यीशु के बनना चाहो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "कुछ करके दिखाना होगा,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "खुद बचना काफी नहीं है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "औरों को बचाना होगा",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "दिल में पहली जगह उसे दो।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "गर यीशु की सेवा करोगे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "अपनी आशिष वह तुमको देगा,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "गर पाप की सेवा करोगे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "हरगिज नहीं माफ करेगा",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "उसके लहू में दिल धो लो।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "यीशु नाम को अपना कहना,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "जैसे काँटों की राहों पर चलना",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "और सच्चे मसीहा बनना,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "संग क्रूस पर उसके मरना,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "जिन्दा रहने को शक्ति ले लो।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    } ]
  } ]
}