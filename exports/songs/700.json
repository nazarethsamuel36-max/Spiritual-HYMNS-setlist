  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Cover me, cover me",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "Extend the border of Thy mantle over me,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 25
      }, {
        "chord" : "G",
        "position" : 32
      }, {
        "chord" : "D",
        "position" : 37
      } ]
    }, {
      "text" : "Because Thou art my nearest kinsman",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "Cover me, cover me, cover me.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "Fear not, fear not",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "My daughter I will do to thee",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "All you need,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 8
      } ]
    }, {
      "text" : "Because thou art a virtuous woman",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "Fear not, fear not."
