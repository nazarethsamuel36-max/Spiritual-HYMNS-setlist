  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "यहोवा चरवाहा मेरा, कोई घटी मुझे नहीं है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    }, {
      "text" : "हरी चराइयों में मुझे, स्नेह से चराता वह है ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 22
