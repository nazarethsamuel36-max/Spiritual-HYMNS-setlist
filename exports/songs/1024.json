  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "मन का दीप जला, जीवन दीप जला",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 15
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "ख्वाबों में खोया है, जाग जरा मतवाले । (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 21
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    }, {
      "text" : "सच बतला दे तेरे मन में, रात कैसी छाई?",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 24
      }, {
        "chord" : "G",
        "position" : 35
      } ]
    }, {
      "text" : "अच्छा नहीं है देख सम्भल जा, यीशु से है जुदाई,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 28
      }, {
        "chord" : "G",
        "position" : 43
      } ]
    }, {
      "text" : "यीशु को अपना । (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "यह दुनिया है ख्वाब सुनहरा, इसमें जो फँस जाये,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 27
      }, {
        "chord" : "G",
        "position" : 42
      } ]
    }, {
      "text" : "रोए तड़पे चैन न पाए, घुल-घुल कर मर जाये,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 21
      }, {
        "chord" : "G",
        "position" : 37
      } ]
    }, {
      "text" : "मन का मैल धुला । (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "यीशु को तू अपने जीवन में अपना मित्र बनाले,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 25
      }, {
        "chord" : "G",
        "position" : 39
      } ]
    }, {
      "text" : "छोड़ दे अब यह दुनिया सुनहरी,"
    }, {
      "text" : "दुनियाँ से मन तू फिराले"
    }, {
      "text" : "होगा तेरा भला । (2)"
    } ]
  } ]
}