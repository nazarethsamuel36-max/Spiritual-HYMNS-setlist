{
  "id" : 1081,
  "songNumber" : 103,
  "title" : "O AKASH AUR SURYA CHANDRAMA",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "ओ आकाश और सूर्य चंद्रमा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "स्तुति करो सारा भूमण्डल ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "यीशु ने तुझ से प्रेम किया,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      } ]
    }, {
      "text" : "तेरे लिए अपना प्राण दिया,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    }, {
      "text" : "नरक से आत्मा को बचा लिया,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      } ]
    }, {
      "text" : "अनंत जीवन सबको दिया ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "अनुग्रहकारी प्रिय यीशु,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      } ]
    }, {
      "text" : "धर्मी हो उसने दुख सहा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    }, {
      "text" : "हरा दिया बैरी शैतान को,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      } ]
    }, {
      "text" : "मृत्यु पर यीशु विजयी हुआ ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "दूतों ने सुनाया सुसमाचार,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      } ]
    }, {
      "text" : "यीशु जी उठा है जरुर,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "जा के बताओ यह समाचार,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      } ]
    }, {
      "text" : "बाजे बजाते गाते जय जयकार ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    } ]
  } ]
}