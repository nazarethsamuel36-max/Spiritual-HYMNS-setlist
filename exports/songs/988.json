        "chord" : "Em",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "यहाँ के सुखो का अंत होगा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      } ]
    }, {
      "text" : "वहाँ के सुखों का अंत न होगा ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
