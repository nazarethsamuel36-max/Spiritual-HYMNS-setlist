        "chord" : "G",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "दुःख जो हमारे यहाँ, ना होंगे फिर वहाँ",
