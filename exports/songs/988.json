        "chord" : "Em",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 33
      } ]
    }, {
      "text" : "यहाँ के दुःखों का अंत होगा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 18
      } ]
    }, {
      "text" : "वहाँ के सुखों का अंत ना होगा ।",
