{
  "id" : 1063,
  "songNumber" : 85,
  "title" : "शुंय सॆ लॆकर् तुनॆ मुझॆ",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "शून्य से लेकर तूने मुझे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "रच लिया अपने ही रुप में ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "प्रेम किया है, अनंत प्रेम से,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "दिया पुत्र मेरे मुक्ति के लिए ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 26
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "अनोखा प्यार है तेरा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 6
      } ]
    }, {
      "text" : "करूंगा स्तुति तेरी मैं सर्वदा (2)",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "जग में आया यीशु स्वर्ग छोड़कर",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "मेरा सारा दर्द सह लिया उसने ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "कोडे खाके क्रुस उठाया यीशुने,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "मुझे मुक्ति और चंगाई दे दी है ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 21
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "अन्न वस्त्र और सभी आशिषे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "दि मुझे उसने भरपुरी से ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "कहाँ और सब मुसीबतों में,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "आँखों की पुतली जैसा संभाला मुझे ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 27
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "अविनाशी अनंत मिरास,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 9
      } ]
    }, {
      "text" : "धन्य संगती, यीशु के साथ ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 17
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "पायेंगे यीशु से जलाली ताज,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    }, {
      "text" : "स्वर्ग में धन्य उसकी संतान ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    } ]
  } ]
}