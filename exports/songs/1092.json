  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "ऐ दुनिया के लोगो, ऊँची आवाज करो",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "Am",
        "position" : 29
      } ]
    }, {
      "text" : "गावो खुशी के गीत, उसका गनगान करो",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 23
      }, {
        "chord" : "Am",
        "position" : 30
      } ]
    }, {
      "text" : "इबादत करो उसकी, इबादत करो",
