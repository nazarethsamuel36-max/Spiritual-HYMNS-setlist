        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "वफाँ का अज़ल से सही सिलसिला है",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 25
      } ]
    }, {
      "text" : "उसपर इमान धरो, उसके घर आवो चलो",
