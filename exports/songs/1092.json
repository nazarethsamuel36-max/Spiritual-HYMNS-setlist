        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "Am",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "याद रखो कि वही एक खुदा है"
    }, {
      "text" : "हमको ये जीवन उसी ने दिया है",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 22
      } ]
    }, {
      "text" : "उस चारागाँसे हम सब है आये",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "हमदो सन्ना के हम गीत गाये",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 23
      } ]
    }, {
      "text" : "रब्ब का तुम शुकर करो, ऊँची आवाज करो,",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "Am",
        "position" : 33
      } ]
    }, {
      "text" : "गावो खुशी के गीत, उसका गुनगान करो ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 23
      }, {
        "chord" : "Am",
        "position" : 31
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "नामे खुदावन्द कितना मुबारक",
