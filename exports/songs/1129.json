        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "ऊँचा हो सारे जगत में सदा",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "अनोखा है यह जीवन हमारा",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "आशिषों से भरपूर है सदा।",
