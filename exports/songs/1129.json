      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "खोया हुआ और दुर हो गया,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "यीशु को मैंने कभी नहीं जाना,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "उसी ने मुझको चुन लिया है।",
