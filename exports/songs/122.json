  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "सुनो सुनो यीशु आयेगा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "अपने संग वो ले जायेगा (2)",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "यीशु को हम सब देखेंगे,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "उसकी महिमा करेंगे (2)",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      } ]
    }, {
      "text" : "स्वर्ग राज्य में हम सब रहेंगे,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "और अनंत जीवन पायेंगे (2)",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "यीशु अपने हाथों से जीस्म को छुआ,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "दुःखियोंके दुःख सब दूर हुआ",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "उसकी नजरमें है सबके लिए प्यार",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "पापीय़ोंको पापसे देता उद्धार",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "सबके दिलों को जानता है वो,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "हाथ पसारे बुलाता है वो (2)",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "जब तक यीशु इस दुनियाँ में घुमता रहा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    }, {
      "text" : "लोगोंकी सेवामें घूमता रहा",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    }, {
      "text" : "किसीने ना जाना उसकी दिलकी पुकार,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "सरपर पहनाया काँटो का हार",
