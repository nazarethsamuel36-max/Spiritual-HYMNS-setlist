        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "दुनियाँ में ऐसी मिसाल नहीं है,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "यीशु से बढ़कर कोई नहीं है (2)",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      } ]
    } ]
  } ]
}