        "position" : 0
      }, {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : "And He will do something new today.",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    } ]
  } ]
