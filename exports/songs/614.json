  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "God will make a way,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 9
      } ]
    }, {
      "text" : "Where there seems to be no way,",
      "chords" : [ {
        "chord" : "G",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "He works in ways we cannot see,",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "He will make a way for me,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 8
      } ]
    }, {
      "text" : "He will make a way.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "He will be my Guide,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 8
      } ]
    }, {
      "text" : "Hold me closely to His side;",
      "chords" : [ {
        "chord" : "G",
        "position" : 5
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "With love and strength for each new day",
      "chords" : [ {
        "chord" : "G",
        "position" : 5
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "He will make a way,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 8
      } ]
    }, {
      "text" : "He will make a way."
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "By a roadway in the wilderness,",
      "chords" : [ {
        "chord" : "G",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 20
      } ]
    }, {
      "text" : "He'll lead me",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      } ]
    }, {
      "text" : "And rivers in the desert will I see,",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 32
      } ]
    }, {
      "text" : "Heaven and Earth will fade but",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "His Word will still remain.",
      "chords" : [ {
