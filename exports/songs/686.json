        "position" : 0
      }, {
        "chord" : "D7",
        "position" : 18
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "To tell the world that Jesus is mine,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 32
      } ]
    }, {
      "text" : "He has given me the wine to make my heart rejoice.",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "D",
