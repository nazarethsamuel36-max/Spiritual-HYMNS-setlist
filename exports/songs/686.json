      "text" : "Magnify His wonderful Name",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 22
      } ]
    }, {
      "text" : "For the glory of the Lord is mine forever,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 21
      }, {
        "chord" : "D7",
        "position" : 29
      }, {
        "chord" : "G",
        "position" : 37
      } ]
    }, {
      "text" : "Jesus is ever the same;",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 9
      }, {
        "chord" : "C",
        "position" : 18
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "For the Lord has set me free,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "And He's given me liberty,",
      "chords" : [ {
