{
  "id" : 1165,
  "songNumber" : 187,
  "title" : "आसमानों में है मेरा भी एक मकान",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "आसमानों में है मेरा भी एक मकान",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "जिसमें रहेंगे, हम जा कर, छोड़ेंगे जब यह जहाँ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "मैं काहे घबराऊँ, मेरा भरोसा वही (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "जिस ने किया है वायदा, वायदा है सच्चा सही (2)",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "जगह बनाऊँगा जाके, अपने पिता के यहाँ,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 31
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "लिखा गया मेम्ने की पुस्तक में मेरा भी नाम",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "मुझ पापी पर जब हुआ था उसके फजल का यह काम",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "उसने बचाया है मुझको वह है बड़ा मेहरबाँ (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "A",
        "position" : 35
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "उसको मोहब्बत है तुमसे, आजमा के देख लो",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "लगाएगा वह गले से, पास आकर देख लो।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "भटके हुआ को बचाने वाला वह है पास आकर देख लो।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 41
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "झूठे जहाँ में तसल्ली हरगिज नहीं पाओगे",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "यीशु के पास बोझ लाओ, तभी आराम पाओगे",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "उस संग रहोगे तुम जाकर, रखोगे गर तुम ईमान।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 23
      }, {
        "chord" : "A",
        "position" : 37
      } ]
    } ]
  } ]
}