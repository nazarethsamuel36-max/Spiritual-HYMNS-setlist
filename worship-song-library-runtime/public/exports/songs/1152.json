{
  "id" : 1152,
  "songNumber" : 174,
  "title" : "TERE SAATH HUM CHALEIN",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "तेरे साथ हम चलें, जीवन तब हमें मिले",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "तेरे पद से हम बढ़े, मंझील तब हमें मिले।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "जिंदगी में थी विरानीया।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "और जीवन सुना सुना था।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "हसीन थी जहाँ की रोशनी।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "मगर मन में अंधकार था।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "कैसे भूले वो घडी,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    }, {
      "text" : "हमको तुम मिले मसीह।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "जिंदगी में रंग भर दिया।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "जिंदगी के राहों में मसीह।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "हमको तुम बढ़ाते चलो।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "आयेगा तुफान राहोंमें।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 17
      } ]
    }, {
      "text" : "तुम रोशनी दिखाते चलो।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "बढ चलेंगे काफिले पा ही लेंगे मंझीले।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "A",
        "position" : 33
      } ]
    }, {
      "text" : "हम सफर हमारा हो गया।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    } ]
  } ]
}