{
  "id" : 1124,
  "songNumber" : 146,
  "title" : "JAI JAI YESHU, JAI JAI YESHU",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "जय जय यीशु, जय जय यीशु",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "जय मृत्युंजय-जयकार",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "सिरजनहार, पालनहार, तारणहार।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "दीनों का दुख हरनेवाला,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "हृदय में शांति भरनेवाला",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "जय जनरंजन, जय दुखभंजन।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "जय जयकार...",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "नर-तन धार लियो अवतारो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "दे निज प्राण कियो छुटकारो,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "जय जगत्राता जय सुखदाता।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "जय जयकार..."
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "मृत्यु के बंधन, भंजनहारा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "अक्षय जीवन देवनहारा",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "रोगिन, शोकिन एक आधारा।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "जय जयकार..."
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "जय-जयकार करो सब प्यारों,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "नर-नारी एक संग पुकारो,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "नारे मारो जय ललकारो।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "जय जयकार..."
    } ]
  } ]
}