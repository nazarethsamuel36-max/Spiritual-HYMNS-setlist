  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Let me walk, blessed Lord, in the way Thou hast gone,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 48
      } ]
    }, {
      "text" : "Leading straight to the land above;",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "Giving cheer everywhere, to the sad and the lone,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 44
      } ]
    }, {
      "text" : "Fill my way every day with love.",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Fill my way every day with love,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "As I walk with the heavenly Dove;",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 28
      } ]
    }, {
      "text" : "Let me go all the while, with a song and a smile,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 32
      } ]
    }, {
      "text" : "Fill my way every day with love."
    }, {
      "text" : ""
    }, {
      "text" : "Keep me close to the side of my Saviour and Guide,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 44
      } ]
    }, {
      "text" : "Let me never in darkness rove;",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 25
      } ]
    }, {
      "text" : "Keep my path free from wrath, and my soul satisfied,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 47
      } ]
    }, {
      "text" : "Fill my way every day with love."
    }, {
      "text" : ""
    }, {
      "text" : "Soon the race will be o'er, and I'll travel no more,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 47
      } ]
    }, {
      "text" : "But abide in my home above;",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : "Let me sing, blessed King, all the way to the shore,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 46
      } ]
    }, {
      "text" : "Fill my way every day with love."
