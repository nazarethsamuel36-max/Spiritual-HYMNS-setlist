{
  "id" : 1164,
  "songNumber" : 186,
  "title" : "हो जय जयकार, जय जयकार करे",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "हो जय जयकार, जय जयकार करे",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "वो है हमारा राजा, दुःख संकट से बचाता।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "हम पर अपनी करुणा करता और करता उपकार",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "क्यों ना उसपर तन-मन हारे दे अपना अधिकार।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "उस पर जिसका भरोसा, वो तो कभी ना गिरेगा",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "चाहे बिमारी, चाहे गरिबी, चाहे हो अकाल",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "सब संकट से सब कष्टों से हो जायेगा पार।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "स्वर्ग है उसका सिंहासन, पृथ्वी बनी है आसन",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "आकाश उसकी महिमा दिखाये, हस्तकला को दिखाये",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "सारी सृष्टी उसकी रचना, उसका ही प्रताप।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    } ]
  } ]
}