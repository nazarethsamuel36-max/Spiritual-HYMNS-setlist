  }, {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "खून की धारा बहती सूली से, जिसमें धुले सब पाप,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 26
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    }, {
      "text" : "धो लो अब तुम अपने हृदय को, जिसमें रहे न दाग ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 27
      }, {
        "chord" : "G",
        "position" : 40
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "ग्रहण करो तुम आज प्रभु को, प्रेम की बहती धार,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 27
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    }, {
      "text" : "उसको बनालो खेवनहारा, नाव लगालो पार ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 21
      }, {
        "chord" : "G",
        "position" : 31
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "वापस आता मेरा प्रभु जी, ले जायेगा साथ,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 24
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    }, {
      "text" : "आशा मेरी अब तो यही है, चलो तुम मेरे साथ ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "हर दम होंगे साथ यीशु के, खुशी और शान्ति, आराम,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 25
      }, {
        "chord" : "G",
        "position" : 42
      } ]
    }, {
      "text" : "आयेगा वह लेने तुम्हें भी, रहना तुम भी तैयार ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "F",
        "position" : 26
      }, {
        "chord" : "G",
        "position" : 40
      } ]
    } ]
  } ]
