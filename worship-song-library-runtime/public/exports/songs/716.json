  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "All Heavens declare",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "The glory of the risen Lord,",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "Who can compare",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "With the beauty of the Lord.",
      "chords" : [ {
        "chord" : "A",
        "position" : 9
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Forever Thou wilt be",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "The Lamb upon the throne.",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "I gladly bow my knee",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      } ]
    }, {
      "text" : "And worship Thee alone.",
      "chords" : [ {
        "chord" : "A",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "I will proclaim",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "The glory of the risen Lord,"
    }, {
      "text" : "Who once was slain",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "To reconcile man to God.",
      "chords" : [ {
        "chord" : "A",
        "position" : 5
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    } ]
  } ]
}