  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Noah had drifted",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "On the floods many days,",
      "chords" : [ {
        "chord" : "G",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "He searched for land",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      } ]
    }, {
      "text" : "In various ways;",
      "chords" : [ {
        "chord" : "A",
        "position" : 5
      } ]
    }, {
      "text" : "Troubles he had some,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "But not from above,",
      "chords" : [ {
        "chord" : "G",
        "position" : 14
      } ]
    }, {
      "text" : "God gave him His sign",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      } ]
    }, {
      "text" : "On the wings of a dove.",
      "chords" : [ {
        "chord" : "A",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "On the wings of a snow-white dove,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    }, {
      "text" : "God sends down His pure, sweet love,",
      "chords" : [ {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "A sign from above,",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      } ]
    }, {
      "text" : "On the wings of a dove."
    }, {
      "text" : ""
    }, {
      "text" : "Jesus, our Saviour",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Came to earth one day;",
      "chords" : [ {
        "chord" : "G",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "He was born in a stable,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "In a manger of hay;",
      "chords" : [ {
        "chord" : "A",
        "position" : 5
      } ]
    }, {
      "text" : "Though here rejected,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "But not from above,"
    }, {
      "text" : "God gave us His sign",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      } ]
    }, {
      "text" : "On the wings of a dove."
    }, {
      "text" : ""
    }, {
      "text" : "Though I have suffered",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "In many a way,",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 10
      } ]
    }, {
      "text" : "I cried for healing",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      } ]
    }, {
      "text" : "Both night and day,",
      "chords" : [ {
        "chord" : "A",
        "position" : 5
      } ]
    }, {
      "text" : "Faith wasn't forgotten",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      } ]
    }, {
      "text" : "By the Father above,",
      "chords" : [ {
        "chord" : "G",
        "position" : 7
      } ]
    }, {
      "text" : "He gave me His sign,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      } ]
    }, {
      "text" : "On the wings of a dove."
    } ]
  } ]
}