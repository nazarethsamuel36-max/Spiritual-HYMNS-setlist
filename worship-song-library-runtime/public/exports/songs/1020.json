{
  "id" : 1020,
  "songNumber" : 42,
  "title" : "DEKHO DEKHO KOI AA RAHA HAI",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "देखो देखो कोई आ रहा है,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : "कैसा जलवा मसीह आ रहा है,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "आँखे अपनी उठाकर तो देखो,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 13
      } ]
    }, {
      "text" : "कैसे शान से मसीह आ रहा है ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "वो भी कैसी सवारी है देखो,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 12
      } ]
    }, {
      "text" : "आसमान की बेदारी तो देखो;",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 11
      } ]
    }, {
      "text" : "बाजे बजते हैं, दूत गाते हैं (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "क्योंकि दुल्हा चला आ रहा है ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "वहाँ सूरज और चाँद है न कोई,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : "अब तो मुरदे पड़े हैं न कोई;",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 12
      } ]
    }, {
      "text" : "हम सब गाते है और नाचते है (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "क्योंकि दुल्हा चला आ रहा है ।"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "यह दुनिया हमारी मिटेगी,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 11
      } ]
    }, {
      "text" : "एक नयी दुनिया फिर से बनेगी;",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "सब नया होगा, जग नया होगा (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "राज्य करने मसीह आ रहा है ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "अब नहीं है वो काँटों का सेहरा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : "वो तो पहने है दुल्हे का सेहरा;",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "जिन्दगी जब तक, कैसी प्यारी दुल्हन (2)",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "जिसको लेने मसीह आ रहा है ।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    } ]
  } ]
}