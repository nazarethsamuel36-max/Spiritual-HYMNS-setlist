      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "Mercydrops round us are falling,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "But for the showers we plead.",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "There shall be showers of blessing,"
    }, {
