      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "Over the hills and the valleys,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Sound of abundance of rain.",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : ""
    }, {
