      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "Grant to us now a refreshing,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Come, and now honor Thy Word.",
      "chords" : [ {
