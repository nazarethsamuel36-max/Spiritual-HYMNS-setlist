        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "मैं ये सोचूँ मैं ये चाहूँ, तेरी मर्जी पूरी करु ।",
      "chords" : [ {
        "chord" : "G",
