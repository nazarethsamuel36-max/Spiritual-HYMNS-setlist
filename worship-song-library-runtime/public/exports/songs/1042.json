        "position" : 20
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    }, {
      "text" : "बलिदान से मुझे खरीदा, परलोक खोल दिया ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
