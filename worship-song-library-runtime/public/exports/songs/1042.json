  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "तेरे लिए जीवन मेरा, तुझसे मैं प्रेम करता",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
