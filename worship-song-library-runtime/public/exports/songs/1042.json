        "position" : 19
      }, {
        "chord" : "G",
        "position" : 35
      } ]
    }, {
      "text" : "मर्जी है तेरी यही, भूलू मैं तुझको नहीं ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 15
      }, {
        "chord" : "D",
