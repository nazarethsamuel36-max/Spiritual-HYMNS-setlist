      }, {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "पत्थर बोल उठेंगे, पत्थर बोल उठेंगे ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
