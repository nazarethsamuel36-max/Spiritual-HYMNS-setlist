{
  "id" : 742,
  "songNumber" : 130,
  "title" : "WE'RE MARCHING TO ZION",
  "language" : "english",
  "originalKey" : "G",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Come, we that love the Lord,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "And let our joys be known,",
      "chords" : [ {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "Join in a song with sweet accord, (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "A",
        "position" : 28
      } ]
    }, {
      "text" : "And thus surround the throne. (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "We're marching to Zion,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      } ]
    }, {
      "text" : "Beautiful, beautiful Zion,",
      "chords" : [ {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "We're marching upward to Zion,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 25
      } ]
    }, {
      "text" : "The beautiful city of God.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Let those refuse to sing",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      } ]
    }, {
      "text" : "Who never knew our God;",
      "chords" : [ {
        "chord" : "G",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "But children of the heavenly King, (2)"
    }, {
      "text" : "May speak their joys abroad. (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "The hill of Zion yields",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      } ]
    }, {
      "text" : "A thousand sacred sweets",
      "chords" : [ {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "Before we reach the heavenly fields, (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "A",
        "position" : 29
      } ]
    }, {
      "text" : "Or walk the golden streets. (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Then let our songs abound,",
      "chords" : [ {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "And every tear be dry;",
      "chords" : [ {
        "chord" : "G",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "We're marching thru Immanuel's ground, (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 25
      } ]
    }, {
      "text" : "To fairer worlds on high. (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    } ]
  } ]
}