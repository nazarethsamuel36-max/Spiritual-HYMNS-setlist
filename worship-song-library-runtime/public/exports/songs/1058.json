{
  "id" : 1058,
  "songNumber" : 80,
  "title" : "APNA DIL KHOLO BAND NA KARO",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "अपना दिल खोलो बंद ना करो (2)",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 22
      } ]
    }, {
      "text" : "आत्मा का रूप धरके,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      } ]
    }, {
      "text" : "राजा यीशु तेरे पास है खड़ा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 23
      } ]
    }, {
      "text" : "हाल्लेलुयाह, हाल्लेलुयाह,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 13
      } ]
    }, {
      "text" : "हाल्लेलुयाह, हाल्लेलुयाह। (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 13
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "उसने कहाँ एलिया आयेगा,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 17
      } ]
    }, {
      "text" : "पुत्रो के मन को पिता और फेरेगा । (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 28
      } ]
    }, {
      "text" : "मेघधनुष्य सिरपर बादल है देखो,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 26
      } ]
    }, {
      "text" : "हाथो में छुटकारे की पुस्तक है देखो । (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 32
      } ]
    }, {
      "text" : "अपना तू सिर ऊँचा कर,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 17
      } ]
    }, {
      "text" : "क्योंकि तेरा छुटकारा निकट है ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "दुल्हा की दुल्हन उसकी सुनती है,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 25
      } ]
    }, {
      "text" : "पीछे ही पीछे उसके चलती है । (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 20
      } ]
    }, {
      "text" : "डरना नहीं तू, मेरे साथी,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 21
      } ]
    }, {
      "text" : "जीवन नैया का यीशु है मांझी । (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 24
      } ]
    }, {
      "text" : "बाबुल से बाहर निकल आ,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 20
      } ]
    }, {
      "text" : "तो तू आसमानी ताज पायेगा ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "गर सुनो आज उसकी आवाज तुम,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 21
      } ]
    }, {
      "text" : "हरगिज नहीं पत्थर बनो तुम । (2)",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 21
      } ]
    }, {
      "text" : "आँखों का सुरमा ले लो,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 20
      } ]
    }, {
      "text" : "मलमल सा कपडा ले लो,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 18
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "जीवन का मार्ग सकरा, चौडे को त्याग दो । (2)",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 34
      } ]
    }, {
      "text" : "छुटकारे की मोहर ले लो,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "Em",
        "position" : 19
      } ]
    }, {
      "text" : "क्योंकी दुल्हा जल्दी आनेवाला है ।",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "Am",
        "position" : 26
      }, {
        "chord" : "Em",
        "position" : 33
      } ]
    } ]
  } ]
}