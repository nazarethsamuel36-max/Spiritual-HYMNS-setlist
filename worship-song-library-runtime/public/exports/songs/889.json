      "text" : "\"Thy strength indeed is small,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    }, {
