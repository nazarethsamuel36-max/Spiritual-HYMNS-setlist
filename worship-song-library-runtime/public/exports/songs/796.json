        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 25
      } ]
    }, {
      "text" : "Let cheerful anthems fill His house,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "While to that sacred shrine I move.",
