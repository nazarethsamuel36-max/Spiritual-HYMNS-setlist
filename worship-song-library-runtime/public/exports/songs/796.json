        "position" : 5
      }, {
        "chord" : "D",
        "position" : 21
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    }, {
      "text" : "He taught me how to watch and pray,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "And live rejoicing every day.",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "A",
