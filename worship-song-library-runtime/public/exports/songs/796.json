  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "O happy day, that fixed my choice",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "On Thee, my Saviour and my God !",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    }, {
      "text" : "Well may this glowing heart rejoice,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "And tell its raptures all abroad.",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "Chorus",
    "lines" : [ {
      "text" : "Happy day, happy day,",
