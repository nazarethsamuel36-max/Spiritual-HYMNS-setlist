        "chord" : "G",
        "position" : 5
      }, {
        "chord" : "D",
        "position" : 21
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "O happy bond, that seals my vows",
