  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "येशु तेरे करीब आने से,"
    }, {
      "text" : "जींदगी मेरी बदल गयी"
    }, {
      "text" : "येशु तेरे छूने से,"
    }, {
      "text" : "जींदगी मेरी सवर गयी"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "तूने मुझे है बचाया,"
    }, {
      "text" : "तूने मुझे सेहलाया...२"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "में धन्यवाद करता रहूंगा,"
    }, {
      "text" : "येशु धन्यवाद करता रहूंगा...२"
    }, {
      "text" : "धन्यवाद, धन्यवाद, धन्यवाद , धन्यवाद (२)"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "में जो पापों में डूबा हुआ था,"
    }, {
      "text" : "और जो तुझसे दूर हुआ था...२"
    }, {
      "text" : "तूने मुझे है छुड़ाया,"
    }, {
      "text" : "अपनी राह पर चलाया...२"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 5",
    "lines" : [ {
      "text" : "येशु ने ऐसा प्रेम किया,"
    }, {
      "text" : "मुझको अपना बेटा बनाया...२"
    }, {
      "text" : "अपना लहू बहाया,"
    }, {
      "text" : "जीवन नया दिलाया...२"
    } ]
  } ]
}