        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "बहुत साल मैं रहा तुझसे दूर,",
