        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "गंदगी गुनाहों की तू धोकर,",
