        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 23
      } ]
    }, {
      "text" : "लापरवाही ने किया दूर,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 14
      }, {
        "chord" : "D",
        "position" : 17
      } ]
    }, {
      "text" : "अनुग्रह और प्रेमकी आशीष,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : "धीरज धर मुझे दिखाया है ।",
