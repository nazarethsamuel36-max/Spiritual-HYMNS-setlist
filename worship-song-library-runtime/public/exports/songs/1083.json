  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "बोझ सबके गुनाह का उठाकर",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "वो लिये जा रहा है ।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 12
      } ]
    }, {
      "text" : "ताज कांटो का सिर पर पहनाया,",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "कितने बेदर्दी से उसको सताया (2)",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 22
      } ]
    }, {
      "text" : "कैसे गिर के जाता था यीशु,",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "क्यों खून उसका बहाया ।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 16
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "क्या खता थी हमारे मसीह की,",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "जालिमों ने जो उसको सजा दी (2)",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 20
      } ]
    }, {
      "text" : "ठोंक दी उसके हाथो में कीलें,",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "फिर भी यीशु ने उनको दुआ दी ।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 22
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "सूली पर था मसीह बेसहारा,",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "उसकी पसली में जब भाला मारा (2)",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 22
      } ]
    }, {
      "text" : "बह चली थी लहू की जो धारा,",
      "chords" : [ {
        "chord" : "Am",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "है उसी में सभों का कफारा ।",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "E",
        "position" : 20
      } ]
    } ]
  } ]
