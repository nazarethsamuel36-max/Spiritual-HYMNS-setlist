  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "I will meet you in the morning,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "Just inside the Eastern Gate,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    }, {
      "text" : "Then be ready, faithful pilgrim,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "Lest with you it be too late.",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "A",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "I will meet you, I will meet you",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    }, {
      "text" : "Just inside the Eastern Gate over there;",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 24
      }, {
        "chord" : "D",
        "position" : 34
      } ]
    }, {
      "text" : "I will meet you, I will meet you,",
      "chords" : [ {
        "chord" : "G",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    }, {
      "text" : "I will meet you in the morning over there.",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 23
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "If you hasten off to glory,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "Linger near the Eastern Gate,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    }, {
      "text" : "For I'm coming in the morning,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "So you'll not have long to wait.",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "A",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "Keep your lamps all trimmed and burning,",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 32
      } ]
    }, {
      "text" : "For the Bridegroom watch and wait;",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 29
      } ]
    }, {
      "text" : "He'll be with us at the meeting,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "Just inside the Eastern Gate.",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "A",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "O the joys of that glad meeting",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "With the saints who for us wait,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "A",
        "position" : 27
      } ]
    }, {
      "text" : "What a blessed, happy meeting,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "Just inside the Eastern Gate."
    } ]
  } ]
}