{
  "id" : 803,
  "songNumber" : 191,
  "title" : "ON A HILL FAR AWAY",
  "language" : "english",
  "originalKey" : "G",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "On a hill far away stood an old rugged cross,",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "The emblem of suffering and shame,",
      "chords" : [ {
        "chord" : "A",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "And I love that old cross where the Dearest and Best,",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "G",
        "position" : 36
      } ]
    }, {
      "text" : "For a world of lost sinners was slain.",
      "chords" : [ {
        "chord" : "A",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "Chorus",
    "lines" : [ {
      "text" : "So I'll cherish the old rugged cross,",
      "chords" : [ {
        "chord" : "A",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : "Till my trophies at last I lay down ;",
      "chords" : [ {
        "chord" : "G",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : "I will cling to the old rugged cross,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 31
      } ]
    }, {
      "text" : "And exchange it some day for a crown.",
      "chords" : [ {
        "chord" : "D",
        "position" : 6
      }, {
        "chord" : "A",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "Oh, that old rugged cross, so despised by the world,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "G",
        "position" : 32
      } ]
    }, {
      "text" : "Has a wondrous attraction for me ;",
      "chords" : [ {
        "chord" : "A",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "For the dear Lamb of God left His glory above,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    }, {
      "text" : "To bear it to dark Calvary.",
      "chords" : [ {
        "chord" : "A",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "In the old rugged cross, stained with blood so divine,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    }, {
      "text" : "A wondrous beauty I see.",
      "chords" : [ {
        "chord" : "A",
        "position" : 2
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "For 'twas on that old cross Jesus suffered and died.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    }, {
      "text" : "To pardon and sanctify me.",
      "chords" : [ {
        "chord" : "A",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "To the old rugged cross I will ever be true,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 31
      } ]
    }, {
      "text" : "Its shame and reproach gladly bear ;",
      "chords" : [ {
        "chord" : "A",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "Then He'll call me some day to my home for away,",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    }, {
      "text" : "Where His glory forever I'll share.",
      "chords" : [ {
        "chord" : "A",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 29
      } ]
    } ]
  } ]
}