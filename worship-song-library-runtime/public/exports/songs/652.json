  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "I lift my hands to the coming king,",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "G",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 23
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "To the great I AM, to you I sing,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "A",
        "position" : 28
      } ]
    }, {
      "text" : "For you're the One",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "Who reigns within my heart.",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "And I will serve no foreign god",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 17
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "Nor any other treasure,",
      "chords" : [ {
        "chord" : "G",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "You are my heart's desire",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "Spirit without measure,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 7
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "Unto your name, I will bring my sacrifice.",
      "chords" : [ {
        "chord" : "G",
        "position" : 10
      }, {
        "chord" : "A",
        "position" : 23
      }, {
        "chord" : "D",
        "position" : 37
      } ]
