        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      } ]
    }, {
      "text" : "जय जयकार, जय जयकार",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "तुने मेरे लिए क्या कुछ ना किया । (2)",
