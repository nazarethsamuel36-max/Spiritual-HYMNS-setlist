        "chord" : "G",
        "position" : 40
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "क्यों ना बोलू फिर",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "मैं तेरी जय जयकार (2)",
