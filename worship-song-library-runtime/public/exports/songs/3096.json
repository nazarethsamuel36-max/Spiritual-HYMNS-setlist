  "title" : "माझा येशु मला प्रिय फार",
  "language" : "marathi",
  "originalKey" : "F",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "माझा येशु मला प्रिय फार"
    }, {
      "text" : "ह्या जीवनात तोच आधार"
    }, {
      "text" : "आपत्तीत विपत्तीत ह्या जीवन यात्रेत"
    }, {
      "text" : "तो कधी ना मला सोडणार"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "हा जीवन प्रवास कठीण,"
    }, {
      "text" : "येते अनेक प्रतिकूल क्षण"
    }, {
      "text" : "दिवसा मेघ स्तंभ, रात्री अग्नी स्तंभ,"
    }, {
      "text" : "माझे वाटाडे प्रति दिन"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "तो आधी व अंत आहे,"
    }, {
      "text" : "हृदयी आनंदाचा झरणा वाहे"
    }, {
      "text" : "दुःख येता क्षणी, अश्रू पुसतो क्षणीच,"
    }, {
      "text" : "माझा प्रतिदिन भार वाहे"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "माझ्या येशु ची अपरंपार प्रीती,"
    }, {
      "text" : "मला नाही कशाची भीती"
    }, {
      "text" : "क्लेश संकट मरण, नग्नता उपोषण,"
    }, {
      "text" : "ख्रिस्ता संगे विजय प्राप्ती"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "माझा येशु मला प्रिय फार"
    }, {
      "text" : "ह्या जीवनात तोच आधार"
    }, {
      "text" : "आपत्तीत विपत्तीत ह्या जीवन यात्रेत"
    }, {
      "text" : "तो कधी न मला सोडणार"
    } ]
  } ]
}