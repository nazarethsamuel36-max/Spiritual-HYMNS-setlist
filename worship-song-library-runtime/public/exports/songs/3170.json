    "label" : "Verse 1",
    "lines" : [ {
      "text" : "Hallowed be Thy Name"
    }, {
      "text" : "Jehovah God You reign"
    }, {
      "text" : "And You will never change, O Lord"
    }, {
      "text" : "Forever You're the same"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "Jehovah-Jireh"
    }, {
      "text" : "You supply my every need"
    }, {
      "text" : "Jehovah-Rapha"
    }, {
      "text" : "Perfect health You give to me"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "Jehovah-Shalom"
    }, {
      "text" : "You're the One who gives me peace"
    }, {
      "text" : "Jehovah-Rohi"
    }, {
      "text" : "My faithful Shepherd leading me"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "Jehovah-Mekaddesh"
    }, {
      "text" : "You're the One who makes me clean"
    }, {
      "text" : "Jehovah-Tsidkenu"
    }, {
      "text" : "Imparting righteousness to me"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 5",
    "lines" : [ {
      "text" : "Jehovah-Nissi"
    }, {
      "text" : "Lord, You reign in victory"
    }, {
      "text" : "Jehovah-Shammah"
    }, {
      "text" : "You are always there for me"
    } ]
