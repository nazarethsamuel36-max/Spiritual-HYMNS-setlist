  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "We magnify your name, Lord,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    }, {
      "text" : "We worship and adore you,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "A",
        "position" : 16
      } ]
    }, {
      "text" : "For who you are, for what you've done"
    }, {
      "text" : "Among your people here.",
      "chords" : [ {
        "chord" : "D",
        "position" : 1
      }, {
        "chord" : "A",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "We open up our lives to you,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 15
      }, {
        "chord" : "D",
        "position" : 24
      } ]
    }, {
      "text" : "Lay down our minds and wills,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "A",
        "position" : 23
      } ]
    }, {
      "text" : "We want you Lord to have your way",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 30
      } ]
    }, {
      "text" : "For we delight in you !",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 9
      }, {
        "chord" : "D",
