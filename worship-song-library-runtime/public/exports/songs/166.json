      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 34
      } ]
    }, {
      "text" : "Soon we'll gather for the harvest home;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 34
      } ]
    }, {
      "text" : "May the Lord of harvest smile upon us,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : "May we hear His blessed, \"Child, well done.\"",
