    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "Jezu, tujim utram kallzacho sontos,"
    }, {
      "text" : "Jezu, tujim utram dolleancho uzvadd,"
    }, {
      "text" : "Jezu, tujim utram jinnecho visvas!"
