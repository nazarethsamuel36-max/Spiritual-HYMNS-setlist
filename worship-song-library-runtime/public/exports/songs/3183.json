      "text" : "Jezu, tujim utram tanel'leank udok,"
    }, {
      "text" : "Jezu, tujim utram bhukel'leank jevonn,"
    }, {
      "text" : "Jezu, tujim utram meloleank jivit!"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
