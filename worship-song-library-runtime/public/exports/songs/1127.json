{
  "id" : 1127,
  "songNumber" : 149,
  "title" : "इंमनुऎल् कॆ लहु सॆ",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "इम्मानुएल के लहू से, एक सोता भरा है,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "जो पापी उसमें लेवा स्नान, रंग पाप का छुटता है।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "वह डाकू उसे क्रूस पर देख, आनंदित हुआ तब,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "हम वैसे पापी उसी में, पाप अपना धोवे सब।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "विश्वास से जब मैं देखता हूँ, उस दोषहीन रूधिर को,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    }, {
      "text" : "मैं तेरी दया का बयान, नित करूं मरने तक।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "हे मेम्ने तेरे रक्त का गुण, कभी न मिटेगा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    }, {
      "text" : "और तेरी मंडली का बखान, सदा लो रहेगा।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "और तब ये ल डबडाती जीभ, कब्र में चुप रहे,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "तब तेरी स्तुति करूंगा, और मीठे रागों से।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 23
      } ]
    } ]
  } ]
}