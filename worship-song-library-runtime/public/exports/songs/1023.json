        "chord" : "G",
        "position" : 13
      }, {
        "chord" : "A",
        "position" : 26
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    }, {
      "text" : "सोचना होगा हर प्राणी को, क्या वह है तैयार?",
