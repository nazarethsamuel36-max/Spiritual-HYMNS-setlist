        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "A",
        "position" : 25
      }, {
        "chord" : "D",
        "position" : 38
      } ]
    }, {
      "text" : "देखो शायद कल न आए, करना न इनकार,",
