  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "हर्ष वाटतो, बहुत हर्ष वाटतो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "माझा आत्मा येशूकडे पाहत राहतो",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "येशू तारितो हो, मला येशू तारितो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "यामुळेच माझा जीवन बहु आनंदतो",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "प्रेम दावितो हो, येशू प्रेम दावितो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 32
      } ]
    }, {
      "text" : "प्रेमानेच लहानथोरा तो बालावितो",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 28
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "प्रिय वाटतो हो, येशू, प्रिय वाटतो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 31
      } ]
    }, {
      "text" : "माझे तन, मन, धन त्यास अर्पितो.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    } ]
  } ]
