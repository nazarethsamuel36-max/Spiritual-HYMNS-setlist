  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "येशूची सेवा आवडे, गेलो सुवेळी त्याकडे,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "तो दावी फार करुणा, माझ्यांत तोष मावेना",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "धन्य वार ! धन्य वार ! जै सारा गेला पापभार",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 30
      } ]
    }, {
      "text" : "सतत आता प्रार्थना, स्तुति आनंद सरेना;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 8
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "धन्य वार ! धन्य वार ! प्रभूने केला जै उद्धार ॥धृ॥",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 30
      }, {
        "chord" : "G",
        "position" : 46
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "केला करार निश्चये, दिली प्रभूने अभये,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    }, {
      "text" : "अंदेशा कां, आतां जीवा ? विसावा घे, जा गौरवा.",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 24
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "तो राहू देई जवळी, नित्याने तोचि संभाळी,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 32
      } ]
    }, {
      "text" : "सुखद स्वर्गी आणुनी ठेवील तो स्वसदनी",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "प्रेमळ माझा प्रभू तो, दास सुखी मी हर्षतो,",
      "chords" : [ {
        "chord" : "G",
