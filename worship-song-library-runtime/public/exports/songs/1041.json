        "position" : 31
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "आत्मा में नाचो, आत्मा में गाओ,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "यीशु में बने रहो, यीशु में बने रहो ।"
    }, {
      "text" : "जैसे मछली बिन पानी के, जिन्दा न रहती है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      }, {
        "chord" : "C",
        "position" : 23
      }, {
        "chord" : "G",
        "position" : 37
      } ]
    }, {
      "text" : "वैसे ही जीवन, बिन यीशु के अधूरी रहती है ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      }, {
        "chord" : "C",
        "position" : 26
      }, {
        "chord" : "G",
        "position" : 37
      } ]
    }, {
      "text" : "भरपूर जीवन पाने को, यीशु में बने रहो,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 16
      }, {
        "chord" : "C",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 33
      } ]
    }, {
      "text" : "यीशु में बने रहो ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 13
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "जो डाली सदा फल लाती है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 12
      } ]
    }, {
      "text" : "उसको वह छाँटता है",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "प्यार प्रभु जिससे करता है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "उसको वह डाँटता है ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    }, {
      "text" : "आत्मा के फलों से भरने को,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 17
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "यीशु में बने रहो, यीशु में बने रहो ।"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "अनन्त जीवन देनेवाला, तुमको बुलाता है,",
