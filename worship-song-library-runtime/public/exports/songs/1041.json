      }, {
        "chord" : "C",
        "position" : 21
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    }, {
      "text" : "सुबह का तारा, महिमा की धारा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "तुमको बुलाता है ।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 13
      } ]
    }, {
      "text" : "यीशु के कामों को, करने को,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 18
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "यीशु में बने रहो, यीशु में बने रहो ।"
    } ]
  } ]
