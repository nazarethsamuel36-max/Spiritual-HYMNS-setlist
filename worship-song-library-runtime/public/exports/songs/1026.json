        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "F",
        "position" : 21
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "चलते चलते नूर में यीशु के साथ-हाल्लेलुयाह",
