        "chord" : "C",
        "position" : 20
      }, {
        "chord" : "F",
        "position" : 28
      } ]
    }, {
      "text" : "दिन और रात उसके पीछे, मैं चलूँगा,",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "F",
        "position" : 30
      } ]
    }, {
      "text" : "नूर में चलूँगा, पीछे चलूँगा,",
      "chords" : [ {
        "chord" : "F",
        "position" : 0
      }, {
        "chord" : "Bb",
        "position" : 12
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "F",
        "position" : 25
      } ]
    }, {
      "text" : "यीशु मेरा मुन्जी मसरूब ।",
