  "sections" : [ {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "नया जीवन मिल गया, परिवर्तन हो गया,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
