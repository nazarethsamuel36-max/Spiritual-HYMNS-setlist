        "position" : 9
      }, {
        "chord" : "D",
        "position" : 18
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "परिवर्तन, परिवर्तन, परिवर्तन ।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      }, {
        "chord" : "D",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "गाए खुशी से गीत प्रभु के,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 12
      } ]
    }, {
      "text" : "जिसने हम सब को है बचाया,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "गाए हम आवाज उठा के,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 8
      } ]
    }, {
      "text" : "सुन ले ज़मीन आसमां ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 15
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "यीशु है दुनियां का उजियाला,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 19
      } ]
    }, {
      "text" : "करता दूर मन का अंधियारा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    }, {
      "text" : "गाएं जय जयकार उस ही के,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 10
      } ]
    }, {
      "text" : "सुन ले जमीन आसमां ।"
    } ]
  } ]
