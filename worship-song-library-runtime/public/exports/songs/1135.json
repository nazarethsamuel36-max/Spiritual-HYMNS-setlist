  "title" : "हुम् विश्वस् सॆ ऎक् दॆश् दॆख्तॆ हैन्",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "हम विश्वास से एक देश देखते है,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "जिसका तेज और सौंदर्य अपार,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "प्रभु मेरे लिए कर रहा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "रहने के लिए जगह तैयार",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "थोडी देर में वहां,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "प्यारो जा के मिलेंगे सभी।",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "सारे श्रम से मिलेगा विश्राम,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "हम न फिर वहां देखेंगे क्लेश,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "रात और दिन मेन्ने के स्तुतिगान,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "गाएंगे जाके हम ऐसे देश।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "प्रेम अनुग्रह आशिष संपूर्ण,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "आनंदपूर्वक सदा खोल के मन,",
      "chords" : [ {
        "chord" : "C",
        "position" : 0
      } ]
    }, {
      "text" : "है यह ईश्वर का प्यारा वरदान,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "करते रहेंगे स्तुति भजन।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 19
      } ]
    } ]
  } ]
