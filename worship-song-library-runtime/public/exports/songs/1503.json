  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "तारक तो सामर्थ्य तो"
    }, {
      "text" : "येशू देव युगानयुग आहे...(२)"
    }, {
      "text" : "हा.. हा.. हा.. हा.. हाल्लेलुया"
    }, {
      "text" : "हो.. हो.. हो.. हो.. होसान्ना...(२)"
    }, {
      "text" : "हाल्लेलुया... हाल्लेलुया..."
    }, {
      "text" : "हाल्लेलुया...(२)"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "चला हो आता त्याकडे"
    }, {
      "text" : "महिमा स्तुती वर्णू...(२)"
    }, {
      "text" : "स्वर्गाच्या देवाला"
    }, {
      "text" : "स्तुतीचे गीत गाऊ...(२)"
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "त्याचा अनुभव घ्या"
    }, {
      "text" : "किती तो चांगला आहे...(२)"
    }, {
      "text" : "सैतानी बंधनातूनी"
    }, {
      "text" : "आपणांस सोडवितो...(२)"
    } ]
  } ]
