    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "हा दिवस प्रभूचा आहे"
    }, {
      "text" : "उल्हास व आनंद करू...(२)"
    }, {
      "text" : "किती थोर तो देव"
    }, {
      "text" : "सर्वस्व आपणांस दिले...(२)"
