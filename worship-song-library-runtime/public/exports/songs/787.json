        "position" : 9
      }, {
        "chord" : "A",
        "position" : 26
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
