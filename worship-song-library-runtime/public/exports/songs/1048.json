        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "D",
        "position" : 17
      }, {
        "chord" : "Em",
        "position" : 34
      } ]
    }, {
      "text" : "सब कुछ रचा गया, तेज उभरकर आया",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      }, {
        "chord" : "Em",
        "position" : 27
      } ]
    }, {
      "text" : "वो ही वचन देहधारी हुआ, मनुष्यों के बीच में रहा । (2)",
