  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "आदि में वचन था, वचन खुदा के साथ था,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
