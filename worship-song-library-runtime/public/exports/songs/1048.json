        "position" : 8
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 28
      }, {
        "chord" : "Em",
        "position" : 32
      } ]
    }, {
      "text" : "वचन ही तो था खुदा,",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "Em",
        "position" : 15
      } ]
    }, {
      "text" : "वो ही वचन देहधारी हुआ, मनुष्यों के बीच में रहा (2)",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 23
      }, {
        "chord" : "Em",
        "position" : 44
      } ]
    }, {
      "text" : "उसमें ही जीवन था, जीवन की ज्योति थी (2)",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 9
      }, {
        "chord" : "D",
        "position" : 18
      }, {
        "chord" : "Em",
        "position" : 33
      } ]
    }, {
      "text" : "ज्योति ने सबको बनाया, अंधकार सब दुर हुआ",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 22
      }, {
        "chord" : "Em",
        "position" : 38
      } ]
    }, {
      "text" : "वो ही वचन देहधारी हुआ, मनुष्यों के बीच में रहा (2)"
    }, {
      "text" : "उस के लिए ही था, उसके ही द्वारा हुआ (2)",
      "chords" : [ {
        "chord" : "Em",
        "position" : 0
