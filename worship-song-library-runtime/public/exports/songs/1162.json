{
  "id" : 1162,
  "songNumber" : 184,
  "title" : "तॆरि शिरिन् अअवज़्, मैन् सुंत हॊऒन् खुद",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "तेरी शिरीन आवाज, मैं सुनता हूँ खुदा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 33
      } ]
    }, {
      "text" : "बुलाती पास उस चश्मे के,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "सलीब से जो बहा।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 12
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "आता हूं मसीह, आता तेरे पास,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "धो के साफ कर चश्मे से,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "जो बहता क्रूस से खास।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "आता कमजोर लाचार,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "देख मेरी हालत को,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 12
      } ]
    }, {
      "text" : "नजाकत से कर पाक-औ-साफ,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 12
      } ]
    }, {
      "text" : "कि एक भी दाग न हो।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "मसीह, तू बख्शता है,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 16
      } ]
    }, {
      "text" : "कामिल प्यार इमान,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "कामिल उम्मेद और चैन आराम,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 16
      } ]
    }, {
      "text" : "जमीन पर और आसमान।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 5",
    "lines" : [ {
      "text" : "तहसीन कफ्फारे को,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 11
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    }, {
      "text" : "तहसीन मुफ्त फजल को,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    }, {
      "text" : "तहसीन मसिह की बख्शिश को,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "अब मिल के सब कहो।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 14
      } ]
    } ]
  } ]
}