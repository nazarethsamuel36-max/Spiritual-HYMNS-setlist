  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Oh, what a wonderful, wonderful day,",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 32
      } ]
    }, {
      "text" : "Day I will never forget,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 20
      } ]
    }, {
      "text" : "After I'd wandered in darkness away,",
      "chords" : [ {
        "chord" : "D",
        "position" : 10
      }, {
        "chord" : "G",
        "position" : 32
      } ]
    }, {
      "text" : "Jesus my Saviour I met,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "Oh, what a tender, compassionate friend,",
      "chords" : [ {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 33
      } ]
    }, {
      "text" : "He met the need of my heart,",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "A",
        "position" : 22
      } ]
    }, {
      "text" : "Shadows dispelling, with joy I am telling.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 25
      } ]
    }, {
      "text" : "He made all the darkness depart!",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "A",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "Heaven came down and glory filled my soul.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 12
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "D",
        "position" : 37
      } ]
    }, {
