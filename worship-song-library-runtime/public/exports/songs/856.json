      "chords" : [ {
        "chord" : "A",
        "position" : 12
      }, {
        "chord" : "D",
        "position" : 38
      } ]
    }, {
      "text" : "My sins were washed away,",
      "chords" : [ {
        "chord" : "G",
        "position" : 3
      }, {
        "chord" : "D",
        "position" : 21
      } ]
    }, {
      "text" : "And my night was turned to day.",
      "chords" : [ {
        "chord" : "A",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "Heaven came down and glory filled my soul."
    } ]
