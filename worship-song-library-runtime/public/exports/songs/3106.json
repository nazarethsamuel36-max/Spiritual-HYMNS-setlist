  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "येसु नाम मिला - २"
    }, {
      "text" : "मेरा जीवन सवर गया - २"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "तुने लहू के कतरों को मेरे लिए बहा दिया"
    }, {
      "text" : "तुने जान बदन दे कर, येशु मुझको बचा लिया"
    }, {
      "text" : "तेरे लहू से"
    }, {
      "text" : "येशु के लहू से....मेरा जीवन"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "तेरा नाम जो लेता है , वो ज़िन्दगी पाता है"
    }, {
      "text" : "तेरी राहों पर चल कर, रूह ईनाम में पाता है"
    }, {
      "text" : "तेरे रूह से - २"
    }, {
      "text" : "खुदा के रूह से"
    }, {
      "text" : "तेरे रूह से....मेरा जीवन"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "येशु तेरी हज़ूरी में, कुदरत और जलाल है"
    }, {
      "text" : "येशु तेरे ही हाथो में, मोजज़ात कमाल है"
    }, {
      "text" : "तेरे छूने से ... - २"
    }, {
      "text" : "खुदा के छूने से"
    }, {
      "text" : "तेरे छूने से....मेरा जीवन"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 5",
    "lines" : [ {
      "text" : "येशु अब मेरे जीवन का, इक तू ही सहारा है"
    }, {
      "text" : "मेरे जीवन की कश्ती का, येशु तू ही किनारा है"
    }, {
      "text" : "येशु तू मिला"
    }, {
      "text" : "हाँ मुझे तू मिला"
    }, {
      "text" : "येशु तू मिला....मेरा जीवन"
    } ]
  } ]
}