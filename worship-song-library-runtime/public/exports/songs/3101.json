  "title" : "** क्या दे सकता हूँ, क्या ला सकता हूँ",
  "language" : "hindi",
  "originalKey" : "F",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "SECTIONS",
    "lines" : [ ]
  }, {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "क्या दे सकता हूँ, क्या ला सकता हूँ"
    }, {
      "text" : "कहता तुझे बस शुक्रिया"
    }, {
      "text" : "..repeat"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "तुझमे ही मेरी सुबह, तुझमे ही हर शाम"
    }, {
      "text" : "तुझसे ही करता शुरू, हर कोई काम"
    }, {
      "text" : "शुक्रिया करता हूँ मैं, लेके तेरा नाम"
    }, {
      "text" : "आदर और धन्यवाद आज तेरे नाम"
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "शुक्रिया शुक्रिया शुक्रिया तेरा"
    }, {
      "text" : "शुक्रिया शुक्रिया शुक्रिया येशू तेरा |"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "सारी दुनिया तेरी है"
    }, {
      "text" : "सब कुछ तुनें रचाया है...२"
    }, {
      "text" : "मुझ को भी तुनें बनाया है"
    }, {
      "text" : "तेरे जैसा किया है"
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 4",
    "lines" : [ {
      "text" : "तू ही मेरा सहारा है,"
    }, {
      "text" : "तूने मुझको बचाया है...२"
    }, {
      "text" : "मेरा जीवन तेरा है,"
    }, {
      "text" : "तुझमे मेरा बसेरा है"
    } ]
  } ]
}