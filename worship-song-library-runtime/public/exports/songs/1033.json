        "position" : 20
      }, {
        "chord" : "D",
        "position" : 34
      } ]
    }, {
      "text" : "सब है हमारे अपने, हमारे लिये कोई गैर नहीं ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
