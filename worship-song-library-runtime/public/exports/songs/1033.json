      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "हर दम जय जय यीशु की,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 12
      } ]
    }, {
      "text" : "उसके सिवा कोई गीत नहीं, (2)",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 19
      } ]
    }, {
      "text" : "आज बना लो अपना प्रभु को,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 12
      } ]
    }, {
      "text" : "और कोई उद्धार नहीं,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 15
      } ]
    }, {
      "text" : "सब हैं हमारे अपने,"
    }, {
