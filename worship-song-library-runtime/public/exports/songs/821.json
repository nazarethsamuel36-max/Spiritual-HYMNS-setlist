      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "G",
        "position" : 19
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "He then is all my hope and stay.",
