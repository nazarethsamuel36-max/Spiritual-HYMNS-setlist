        "position" : 3
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "A",
        "position" : 28
      } ]
    }, {
      "text" : "Than Jesus' blood and righteousness;",
      "chords" : [ {
        "chord" : "D",
        "position" : 5
      }, {
        "chord" : "A",
        "position" : 22
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : "I dare not trust the sweetest frame,",
