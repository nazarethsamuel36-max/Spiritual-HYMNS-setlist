        "position" : 2
      }, {
        "chord" : "G",
        "position" : 21
      }, {
        "chord" : "A",
        "position" : 30
      } ]
    }, {
      "text" : "But wholly lean on Jesus' name.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 19
      }, {
        "chord" : "D",
        "position" : 26
      } ]
    } ]
  }, {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "On Christ, the solid Rock, I stand;",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "All other ground is sinking sand,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 20
      } ]
    }, {
