        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "A",
        "position" : 16
      }, {
        "chord" : "D",
        "position" : 25
      } ]
    }, {
      "text" : "In every high and stormy gale,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 25
      } ]
    }, {
      "text" : "My anchor holds within the veil.",
