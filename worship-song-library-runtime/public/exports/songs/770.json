{
  "id" : 770,
  "songNumber" : 158,
  "title" : "GREAT IS THY FAITHFULNESS",
  "language" : "english",
  "originalKey" : "D",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "Great is Thy faithfulness,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "O God my Father,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 9
      } ]
    }, {
      "text" : "There is no shadow of turning with Thee;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 35
      } ]
    }, {
      "text" : "Thou changest not,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Thy compassions, they fail not;",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "As Thou hast been Thou forever wilt be.",
      "chords" : [ {
        "chord" : "A",
        "position" : 26
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Great is Thy faithfulness !",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    }, {
      "text" : "Great is Thy faithfulness !"
    }, {
      "text" : "Morning by morning new mercies I see;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 23
      }, {
        "chord" : "D",
        "position" : 33
      } ]
    }, {
      "text" : "All I have needed Thy hand hath provided;",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 35
      } ]
    }, {
      "text" : "Great is Thy faithfulness,"
    }, {
      "text" : "Lord, unto me !",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 11
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Summer and winter, and springtime and harvest,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 38
      } ]
    }, {
      "text" : "Sun, moon and stars in their courses above,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 38
      } ]
    }, {
      "text" : "Join with all nature in manifold witness,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 33
      } ]
    }, {
      "text" : "To Thy great faithfulness, mercy and love.",
      "chords" : [ {
        "chord" : "D",
        "position" : 18
      }, {
        "chord" : "A",
        "position" : 37
      } ]
    }, {
      "text" : ""
    }, {
      "text" : "Pardon for sin and a peace that endureth,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 34
      } ]
    }, {
      "text" : "Thy own dear presence to cheer and to guide,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 38
      } ]
    }, {
      "text" : "Strength for today and bright hope for tomorrow,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 41
      } ]
    }, {
      "text" : "Blessings all mine, with ten thousand beside !",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 40
      } ]
    } ]
  } ]
}