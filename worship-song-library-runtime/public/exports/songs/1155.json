{
  "id" : 1155,
  "songNumber" : 177,
  "title" : "यीशु की बाबत सुनाओ-हो ताकि वह दिल नशीन",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "यीशु की बाबत सुनाओ-हो ताकि वह दिल नशीन,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "यीशु की बातें बेश-कीमती-शहद से ज्यादा शीरीन,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    }, {
      "text" : "कहो कि क्यों कर फरिश्ते-गाते थे हम्द ओ सिपास,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 24
      } ]
    }, {
      "text" : "जबकि खुदावन्द ने आके-पहिना हमारा लिबास।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "यीशु की बाबत सुनाओ,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "हों ताकि वह दिल नशीन।",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "यीशु की बातें बेश कीमत,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "शहद से ज्यादा शीरीन।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 3",
    "lines" : [ {
      "text" : "कहो वह बातें अजूबा, तनाह जब जंगल में था,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "जहाँ कि दुश्मन हमारा-मुंजी से लड़कर गिरा,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "कहो सब उसकी मुसीबत- कहो सब उसका अजार,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "कहो वह मेहनत व दिक्कत- कहो वह उसका प्यार।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 35
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 4",
    "lines" : [ {
      "text" : "कहो कि क्यों कर वह मुआ-",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "क्यों कर वह हुआ म'सलूब,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      } ]
    }, {
      "text" : "क्यों कर वह मर कर फिर जिया-",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "क्यों कर वह मेरा महबूब,",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      } ]
    }, {
      "text" : "उल्फत ए-मुंजी मसीहा, दिल को है कैसी लजी़ज।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "यीशु है मेरा मुंजी, यीशु है मेरा अजी़ज।",
      "chords" : [ {
        "chord" : "A",
        "position" : 0
      }, {
        "chord" : "D",
        "position" : 34
      } ]
    } ]
  } ]
}