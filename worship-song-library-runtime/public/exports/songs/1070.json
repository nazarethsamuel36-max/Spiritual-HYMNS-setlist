{
  "id" : 1070,
  "songNumber" : 92,
  "title" : "मैन् जब् पुकरु तुझॆ",
  "language" : "hindi",
  "capo" : 0,
  "bpm" : 0,
  "timeSignature" : "4/4",
  "hashtags" : [ ],
  "sections" : [ {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "मैं जब पुकारु तुझे, दे दे सहारा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 20
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    }, {
      "text" : "मुझको मिलता प्रभु तुझसे सहारा ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 27
      } ]
    }, {
      "text" : "तू ही है सहारा, तू ही है किनारा,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 16
      }, {
        "chord" : "G",
        "position" : 29
      } ]
    }, {
      "text" : "तू ही है मेरा, तारणहारा ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "तू ने पुकारा, मैं चला आया,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 14
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "तू ही है मेरा, खेवनहारा ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 21
      } ]
    }, {
      "text" : "ले चल मसीहा, चाहे जहाँ तू,",
      "chords" : [ {
        "chord" : "G",
        "position" : 0
      }, {
        "chord" : "C",
        "position" : 13
      }, {
        "chord" : "G",
        "position" : 23
      } ]
    }, {
      "text" : "मेरा तू है, जीवनदाता ।",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    } ]
  } ]
}