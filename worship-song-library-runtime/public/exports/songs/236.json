  "sections" : [ {
    "type" : "chorus",
    "label" : "CHORUS",
    "lines" : [ {
      "text" : "Jesus is the answer for the world today,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "G",
        "position" : 28
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    }, {
      "text" : "Above Him there's no other",
      "chords" : [ {
        "chord" : "D",
        "position" : 1
      }, {
        "chord" : "A",
        "position" : 21
      } ]
    }, {
      "text" : "For Jesus is the way. (Repeat)",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 1",
    "lines" : [ {
      "text" : "If you have any questions in the corners of your mind,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      }, {
        "chord" : "G",
        "position" : 33
      }, {
        "chord" : "D",
        "position" : 49
      } ]
    }, {
      "text" : "Traces of discouragement,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 13
      } ]
    }, {
      "text" : "Peace you cannot find,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 17
      } ]
    }, {
      "text" : "Reflections of your past",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "Seem to face you day by day,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 24
      } ]
    }, {
      "text" : "There's one thing I'm sure of:",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      } ]
    }, {
      "text" : "Jesus is the way.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 13
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "VERSE 2",
    "lines" : [ {
      "text" : "I know you've got mountains",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "That you think you cannot climb,",
      "chords" : [ {
        "chord" : "D",
        "position" : 9
      }, {
        "chord" : "A",
        "position" : 26
      } ]
    }, {
      "text" : "I know your skies are dark you think",
      "chords" : [ {
        "chord" : "D",
        "position" : 2
      }, {
        "chord" : "G",
        "position" : 22
      } ]
    }, {
      "text" : "The sun won't shine.",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "A",
        "position" : 14
      } ]
    }, {
      "text" : "In case you don't know,",
      "chords" : [ {
        "chord" : "D",
        "position" : 3
      }, {
        "chord" : "G",
        "position" : 18
      } ]
    }, {
      "text" : "But the Word of God is true,",
      "chords" : [ {
        "chord" : "D",
        "position" : 8
      }, {
        "chord" : "A",
        "position" : 23
      } ]
    }, {
      "text" : "And everything He's promised,",
      "chords" : [ {
        "chord" : "D",
        "position" : 4
      }, {
        "chord" : "G",
        "position" : 20
      } ]
    }, {
      "text" : "He will do it for you.",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      }, {
        "chord" : "A",
        "position" : 8
      }, {
        "chord" : "D",
        "position" : 18
      } ]
    } ]
  } ]
}