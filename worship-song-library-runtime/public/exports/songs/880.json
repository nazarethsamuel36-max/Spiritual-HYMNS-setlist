        "chord" : "D",
        "position" : 11
      }, {
        "chord" : "G",
        "position" : 20
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    }, {
      "text" : "\"Draw from my well that never shall run dry.\"",
