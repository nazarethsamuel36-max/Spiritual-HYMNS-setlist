  "sections" : [ {
    "type" : "verse",
    "label" : "Verse 1",
    "lines" : [ {
      "text" : "Hark! 'tis the Shepherd's voice I hear,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Out in the desert dark and drear,",
      "chords" : [ {
        "chord" : "A",
        "position" : 4
      }, {
        "chord" : "D",
        "position" : 27
      } ]
    }, {
      "text" : "Calling the sheep who've gone astray,",
      "chords" : [ {
        "chord" : "D",
        "position" : 12
      } ]
    }, {
      "text" : "Far from the Shepherd's fold away.",
      "chords" : [ {
