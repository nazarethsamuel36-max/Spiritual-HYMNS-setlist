        "position" : 20
      }, {
        "chord" : "D",
        "position" : 28
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 2",
    "lines" : [ {
      "text" : "Who'll go and help this Shepherd kind,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
      "text" : "Help Him the wand'ring ones to find ?",
      "chords" : [ {
        "chord" : "A",
        "position" : 5
      }, {
        "chord" : "D",
        "position" : 31
      } ]
    }, {
      "text" : "Who'll bring the lost ones to the fold,",
      "chords" : [ {
        "chord" : "D",
        "position" : 7
      } ]
    }, {
      "text" : "Where they'll be sheltered from the cold ?",
      "chords" : [ {
        "chord" : "A",
        "position" : 6
      }, {
        "chord" : "D",
        "position" : 36
      } ]
    } ]
  }, {
    "type" : "verse",
    "label" : "Verse 3",
    "lines" : [ {
      "text" : "Out in the desert hear their cry,",
      "chords" : [ {
        "chord" : "D",
        "position" : 0
      } ]
    }, {
