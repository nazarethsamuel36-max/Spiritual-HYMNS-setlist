        "position" : 0
      }, {
        "chord" : "A",
        "position" : 26
      }, {
        "chord" : "G",
        "position" : 26
      } ]
    }, {
      "text" : "Bring them in from the fields of sin;",
      "chords" : [ {
        "chord" : "D",
        "position" : 23
      } ]
    }, {
      "text" : "Bring them in, bring them in,"
    }, {
      "text" : "Bring the wand'ring ones to Jesus.",
